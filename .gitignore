# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
out/

# ─── Astro cache ──────────────────────────────────────────────────────────────
.astro/

# ─── Environment files (contain secrets) ─────────────────────────────────────
.env
.env.*
!.env.example

# ─── Test / coverage ──────────────────────────────────────────────────────────
coverage/
playwright-report/
test-results/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS / editor noise ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ─── Temp ─────────────────────────────────────────────────────────────────────
tmp/
temp/
.cache/
