---
import { ArrowLeft, MessageCircle } from "@lucide/astro";
import type { PortfolioDemo } from "../data/portfolioDemos";

interface Props {
  demo: PortfolioDemo;
}

const { demo } = Astro.props;
const src = `/demos/${demo.slug}/index.html`;
const packageRequestHref = `/?package=${encodeURIComponent(`${demo.packageFit} - ${demo.tier}`)}#project-request`;
---

<div class="html-demo-root" style={`--demo-primary:${demo.primary};--demo-secondary:${demo.secondary};--demo-dark:${demo.dark};`}>
  <header class="html-demo-nav">
    <nav class="html-demo-nav__inner" aria-label="Demo navigation">
      <a href="/portfolio/" class="html-demo-nav__back">
        <ArrowLeft class="h-4 w-4" aria-hidden="true" />
        All demos
      </a>
      <a href="/" class="html-demo-nav__logo" aria-label="Mavora Labs home">
        <img src="/logo-transparent.png" alt="Mavora Labs" width="980" height="313" />
      </a>
      <a href={packageRequestHref} class="html-demo-nav__cta">
        <MessageCircle class="h-4 w-4" aria-hidden="true" />
        <span class="html-demo-nav__cta-text">Get this built</span>
      </a>
    </nav>
  </header>

  <div class="html-demo-frame-wrap">
    <iframe
      src={src}
      title={`${demo.name} landing page demo`}
      class="html-demo-frame"
      loading="eager"
      allow="same-origin"
    ></iframe>
  </div>
</div>

<style>
  .html-demo-root {
    display: flex;
    flex-direction: column;
    height: 100svh;
    background: var(--demo-dark);
  }

  .html-demo-nav {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--demo-dark) 88%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255 255 255 / 0.1);
    flex-shrink: 0;
  }

  .html-demo-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: 72rem;
    margin: 0 auto;
    padding: 0.75rem 1.25rem;
  }

  @media (min-width: 640px)  { .html-demo-nav__inner { padding-left: 1.5rem; padding-right: 1.5rem; } }
  @media (min-width: 1024px) { .html-demo-nav__inner { padding-left: 2rem;   padding-right: 2rem;   } }

  .html-demo-nav__back {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255 255 255 / 0.75);
    text-decoration: none;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .html-demo-nav__back:hover { color: #fff; }

  .html-demo-nav__logo {
    display: flex;
    height: 2rem;
    width: 8rem;
    align-items: center;
    border-radius: 9999px;
    background: #fff;
    padding: 0 0.75rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .html-demo-nav__logo img {
    height: auto;
    width: 100%;
    object-fit: contain;
    display: block;
  }

  .html-demo-nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    border-radius: 9999px;
    background: var(--demo-primary);
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    transition: filter 0.15s;
    white-space: nowrap;
  }
  .html-demo-nav__cta:hover { filter: brightness(1.12); }

  @media (max-width: 480px) {
    .html-demo-nav__cta-text { display: none; }
    .html-demo-nav__cta { padding: 0.5rem 0.75rem; }
  }

  .html-demo-frame-wrap {
    flex: 1;
    min-height: 0;
  }

  .html-demo-frame {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }
</style>
