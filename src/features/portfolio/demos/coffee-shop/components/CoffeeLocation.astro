---
import { MapPin, Navigation, Phone } from "@lucide/astro";
import type { CoffeeBusiness } from "../data";
interface Props { business: CoffeeBusiness; }
const { business } = Astro.props;
---
<section id="coffee-location" class="coffee-location-section px-5 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-stretch">
    <div class="coffee-map-card">
      <iframe title="Map to Mavora Coffee" src={business.mapEmbedSrc} loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
    <div class="coffee-contact-card p-8">
      <h2 class="mt-2 text-4xl font-semibold tracking-tight text-white sm:text-5xl">Come in, sit down,<br /><span class="coffee-focus-word">stay a while.</span></h2>
      <p class="coffee-section-copy mt-4">We are in Subang Jaya, easy to find and open every morning.<br />Drop by, or call ahead to check on today's specials.</p>
      <ul class="coffee-location-list mt-6">
        <li><MapPin class="h-4 w-4 text-[var(--coffee-secondary)]" aria-hidden="true" />{business.address}</li>
        <li><Phone class="h-4 w-4 text-[var(--coffee-secondary)]" aria-hidden="true" />{business.phoneDisplay}</li>
      </ul>
      <div class="coffee-hours-grid">
        {business.hoursRows.map((row) => (<div><span>{row.days}</span><strong>{row.hours}</strong></div>))}
      </div>
      <div class="mt-7 flex flex-col gap-3 sm:flex-row">
        <a href={business.phoneHref} class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-[var(--coffee-primary)] px-5 text-sm font-semibold text-white transition hover:brightness-90">Call us<Phone class="h-4 w-4" aria-hidden="true" /></a>
        <a href={business.mapHref} target="_blank" rel="noreferrer" class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full border border-white/24 px-5 text-sm font-semibold text-white transition hover:bg-white/10">Get directions<Navigation class="h-4 w-4" aria-hidden="true" /></a>
      </div>
    </div>
  </div>
</section>
