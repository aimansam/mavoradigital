---
import BurgerBehavior from "./components/BurgerBehavior.astro";
import BurgerAnimations from "./components/BurgerAnimations.astro";
import BurgerHeader from "./components/BurgerHeader.astro";
import BurgerLandingSections from "./components/BurgerLandingSections.astro";
import { burgerBusiness, burgerMenu, burgerReviews, burgerValueSlides } from "./data";
import { burgerBusinessBm, burgerMenuBm, burgerReviewsBm, burgerValueSlidesBm } from "./data.bm";
import "./styles/burger.css";

interface Props {
  demo: {
    image: string;
  };
  lang?: "en" | "bm";
}

const { demo, lang = "en" } = Astro.props;
const isBm = lang === "bm";
const business = isBm ? burgerBusinessBm : burgerBusiness;
const menu = isBm ? burgerMenuBm : burgerMenu;
const slides = isBm ? burgerValueSlidesBm : burgerValueSlides;
const reviews = isBm ? burgerReviewsBm : burgerReviews;
const footerText = isBm ? "Privasi" : "Privacy";
---

<BurgerHeader lang={lang} />
<main data-burger-demo-page>
  <BurgerLandingSections demo={demo} business={business} menu={menu} slides={slides} reviews={reviews} lang={lang} />
</main>
<footer class="burger-footer">
  <p>&copy; 2026 Mavora Burgers &middot; <a href="#">{footerText}</a></p>
</footer>
<BurgerAnimations />
<BurgerBehavior business={business} lang={lang} />