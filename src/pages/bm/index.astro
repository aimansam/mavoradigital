---
import "../../styles/global.css";
import { ArrowRight, CircleCheck, MessageCircle } from "@lucide/astro";
import FloatingLines from "../../components/FloatingLines.jsx";
import LightRays from "../../components/LightRays.jsx";
import LiquidEther from "../../components/LiquidEther.jsx";
import ScrollStack, { ScrollStackItem } from "../../components/ScrollStack.jsx";
import ProcessCardStack from "../../components/ProcessCardStack.jsx";
import SiteHeader from "../../components/SiteHeader.astro";
import { portfolioDemos } from "../../features/portfolio/data/portfolioDemos";
import { HeroParallax } from "../../components/HeroParallax";
import {
  bmSiteUrl,
  budgetOptions,
  businessTypes,
  contentReadinessOptions,
  ctaHref,
  domainOwnershipOptions,
  featureOptions,
  footer,
  formLabels,
  header,
  hero,
  metadata,
  motionBand,
  navigation,
  packageTierOptions,
  packages,
  packagesSection,
  pageOptions,
  portfolio,
  process as processSection,
  request,
  services,
  siteUrl,
  studioStatement,
  timelineOptions,
  websiteTypes,
} from "../../data/site/home.bm";

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || "";
const socialPreview = metadata.socialPreview;
const formCopy = {
  request,
  formLabels,
  packageFallbacks: {
    title: formLabels.packageEmptyTitle,
    text: formLabels.packageEmptyText,
    scope: "Scope akan disahkan",
    timeline: "Timeline akan disahkan",
    free: "Disahkan selepas semakan scope",
  },
};
---

<!doctype html>
<html lang="ms-MY">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#181512" />
    <meta name="description" content={metadata.description} />
    <link rel="canonical" href={bmSiteUrl} />
    <link rel="alternate" hreflang="en" href={siteUrl} />
    <link rel="alternate" hreflang="ms-MY" href={bmSiteUrl} />
    <link rel="alternate" hreflang="x-default" href={siteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={bmSiteUrl} />
    <meta property="og:title" content={metadata.title} />
    <meta property="og:description" content={metadata.description} />
    <meta property="og:image" content={socialPreview} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Mavora Digital — Website yang bantu bisnes jana jualan" />
    <meta property="og:locale" content="ms_MY" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metadata.title} />
    <meta name="twitter:description" content={metadata.description} />
    <meta name="twitter:image" content={socialPreview} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=IM+Fell+French+Canon:ital@0;1&family=Cormorant+Infant:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="icon" href="/logo-transparent.png" />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Mavora Digital",
      "url": "https://mavoralabs.com",
      "logo": "https://mavoralabs.com/logo.png",
      "description": "Mavora Digital membina laman web yang kemas dan laju untuk membantu bisnes mendapat kepercayaan, pertanyaan yang berkualiti, dan lebih banyak jualan.",
      "areaServed": {
        "@type": "Country",
        "name": "Malaysia"
      },
      "serviceType": ["Reka Bentuk Web", "Pembangunan Web", "Reka Bentuk Landing Page", "Reka Bentuk Website Bisnes"],
      "priceRange": "RM800–RM5500+",
      "availableLanguage": ["English", "Malay"],
      "sameAs": []
    }
    </script>
  </head>
  <body class="text-ink antialiased">
    <a href="#services" class="skip-nav">Langkau ke kandungan</a>
    <SiteHeader
      navigation={navigation}
      ctaHref={ctaHref}
      currentLocale="bm"
      navAriaLabel={header.navAriaLabel}
      homeAriaLabel={header.homeAriaLabel}
      menuOpenLabel={header.menuOpenLabel}
      menuCloseLabel={header.menuCloseLabel}
      ctaLabel={header.ctaLabel}
      ctaLabelShort={header.ctaLabelShort}
    />

    <main id="top">
      <HeroParallax
        client:load
        heading={hero.title.join(" ")}
        subheading={hero.copy}
        kicker={hero.kicker}
        ctaHref={ctaHref}
        ctaLabel={hero.primaryCta}
        ctaSecondaryHref="#services"
        ctaSecondaryLabel={hero.secondaryCta}
        products={[
          { title: "Halaman jualan", link: "#packages", thumbnail: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600&q=80" },
          { title: "Website bisnes", link: "#packages", thumbnail: "https://images.unsplash.com/photo-1497366216548-37526070297c?w=600&q=80" },
          { title: "Halaman servis", link: "#services", thumbnail: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&q=80" },
          { title: "Portfolio site", link: "#portfolio", thumbnail: "https://images.unsplash.com/photo-1507238691740-187a5b1d37b8?w=600&q=80" },
          { title: "Ecommerce page", link: "#packages", thumbnail: "https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=600&q=80" },
          { title: "Website restoran", link: "#portfolio", thumbnail: "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=600&q=80" },
          { title: "Studio kecantikan", link: "#portfolio", thumbnail: "https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=600&q=80" },
          { title: "Portfolio freelancer", link: "#portfolio", thumbnail: "https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=600&q=80" },
          { title: "Website agensi", link: "#services", thumbnail: "https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=600&q=80" },
          { title: "Site perundingan", link: "#services", thumbnail: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=600&q=80" },
          { title: "Halaman produk", link: "#packages", thumbnail: "https://images.unsplash.com/photo-1531297484001-80022131f5a1?w=600&q=80" },
          { title: "Bisnes automotif", link: "#portfolio", thumbnail: "https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?w=600&q=80" },
          { title: "Halaman kedai", link: "#packages", thumbnail: "https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=600&q=80" },
          { title: "Servis profesional", link: "#services", thumbnail: "https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=600&q=80" },
          { title: "Website bisnes lokal", link: "#packages", thumbnail: "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=600&q=80" },
        ]}
      />

      <section class="motion-band border-y border-line bg-paper" aria-label="Highlight delivery projek">
        <div class="motion-band__marquee py-5 sm:py-6">
          {[0, 1].map((repeatIndex) => (
            <div class="motion-band__group" aria-hidden={repeatIndex === 1 ? "true" : undefined}>
              {motionBand.map((item) => <span>{item}</span>)}
            </div>
          ))}
        </div>
      </section>

      <section class="credibility-bar bg-ink text-white" aria-label="Studio sekilas">
        <div class="credibility-bar__inner mx-auto max-w-6xl">
          <div class="credibility-stat"><strong>7</strong><span>Konsep demo dibina</span></div>
          <div class="credibility-stat"><strong>3</strong><span>Pakej tersedia</span></div>
          <div class="credibility-stat"><strong>WhatsApp&#8209;first</strong><span>Tiada form panjang. Terus ke WhatsApp.</span></div>
          <div class="credibility-stat"><strong>Fokus Malaysia</strong><span>Pasaran lokal, tawaran lokal</span></div>
        </div>
      </section>

      <section class="studio-statement story-section bg-ink px-5 py-20 text-white sm:px-6 lg:px-8">
        <div class="liquid-section-bg liquid-section-bg--statement" aria-hidden="true">
          <LiquidEther
            client:visible
            colors={["#9ff58f", "#176b4d", "#063b2c"]}
            mouseForce={18}
            cursorSize={116}
            resolution={0.5}
            autoSpeed={0.46}
            autoIntensity={2.05}
            autoResumeDelay={1600}
            autoRampDuration={0.8}
          />
        </div>
        <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.88fr_1.12fr] lg:items-start">
          <div class="studio-motion studio-motion--headline">
            <p class="topic-label text-white/68">{studioStatement.kicker}</p>
            <h2 class="story-heading mt-4 text-4xl font-semibold tracking-normal sm:text-5xl">{studioStatement.title}</h2>
          </div>
          <div class="studio-statement__copy studio-motion studio-motion--copy">
            <p class="studio-statement__intro text-lg leading-8 text-white/74">{studioStatement.intro}</p>
            <ul class="studio-principles" aria-label="Prinsip website Mavora Digital">
              {studioStatement.principles.map((principle, index) => (
                <li>
                  <span class="studio-principles__index">0{index + 1}</span>
                  <div>
                    <h3>{principle.title}</h3>
                    <p>{principle.body}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <section id="services" class="story-section bg-paper px-5 py-20 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
          <div class="max-w-2xl">
            <p class="topic-label text-ember">Servis kami</p>
            <h2 class="story-heading mt-4 text-4xl font-semibold tracking-normal text-ink sm:text-5xl">Servis yang bantu website anda bina trust dan inquiry.</h2>
          </div>
          <div class="svc3d-stage">
            <div class="svc3d-scene" id="svc3d-scene">
              {services.map((service, i) => {
                const Icon = service.icon;
                return (
                  <article class="svc3d-card service-card" data-index={i}>
                    <div class="service-card__top">
                      <span class="service-card__icon inline-flex h-11 w-11 items-center justify-center rounded-full">
                        <Icon class="h-5 w-5" aria-hidden="true" />
                      </span>
                      <h3 class="service-card__title text-xl font-semibold">{service.title}</h3>
                    </div>
                    <p class="service-card__desc mt-6 leading-7">{service.description}</p>
                    <ul class="service-card__points mt-6">
                      {service.points.map((point) => <li>{point}</li>)}
                    </ul>
                  </article>
                );
              })}
              <button class="pkg3d-btn" id="svc3d-prev" aria-label="Previous service" type="button">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
              </button>
              <button class="pkg3d-btn" id="svc3d-next" aria-label="Next service" type="button">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </button>
            </div>
            <div class="pkg3d-controls">
              <div class="pkg3d-dots" role="tablist" aria-label="Service selector">
                {services.map((svc, i) => (
                  <button class={`pkg3d-dot svc3d-dot${i === 0 ? " is-active" : ""}`} type="button" role="tab" aria-label={svc.title}></button>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="portfolio" class="portfolio-section story-section" aria-label="Portfolio demos">
        <div class="light-rays-section-bg light-rays-section-bg--portfolio" aria-hidden="true">
          <LightRays client:visible raysOrigin="top-center" raysColor="#9ff58f" raysSpeed={3.2} lightSpread={2.35} rayLength={2.6} followMouse={true} mouseInfluence={0.48} noiseAmount={0.18} distortion={0.16} fadeDistance={2.7} saturation={1.0} pulsating={true} />
        </div>
        <ul class="pf-slider" id="pf-slider">
          {portfolioDemos.map((demo) => (
            <li class="pf-item" style={`background-image: url('${demo.image}')`} data-slug={demo.slug}>
              <div class="pf-content">
                <p class="pf-eyebrow">{demo.businessType}</p>
                <h2 class="pf-title">{demo.name}</h2>
                <p class="pf-desc">{demo.headline}</p>
                <a href={`/portfolio/${demo.slug}/`} class="pf-cta">View demo</a>
              </div>
            </li>
          ))}
        </ul>
        <nav class="pf-nav">
          <button class="pf-btn pf-prev" id="pf-prev" aria-label="Previous demo" type="button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <button class="pf-btn pf-next" id="pf-next" aria-label="Next demo" type="button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        </nav>
        <div class="pf-view-all">
          <a href="/portfolio/" class="ui-button inline-flex items-center gap-2 rounded-full bg-white px-5 py-3 text-sm font-semibold text-ink transition hover:bg-mist">
            {portfolio.cta}
            <ArrowRight class="h-4 w-4" aria-hidden="true" />
          </a>
        </div>
      </section>

      <section id="packages" class="story-section bg-paper px-5 py-12 sm:px-6 lg:px-8" style="--section-bg: #fbf7ef">
        <div class="mx-auto max-w-6xl">
          <div class="text-center">
            <p class="topic-label text-ember">{packagesSection.kicker}</p>
            <h2 class="story-heading mt-4 text-4xl font-semibold tracking-normal text-ink sm:text-5xl">{packagesSection.title}</h2>
          </div>
          <div class="pkg3d-stage">
            <div class="pkg3d-scene" id="pkg3d-scene">
              {packages.map((item, index) => (
                <article class="pkg3d-card package-card" data-index={index}>
                  <div class="card-summary">
                    <span class="card-index">0{index + 1}</span>
                    <h3 class="text-2xl font-semibold">{item.name}</h3>
                    <p class="package-price">{item.price}</p>
                  </div>
                  <ul class="card-pill-list">
                    {item.points.map((point) => <li><CircleCheck class="h-4 w-4 shrink-0 text-moss" aria-hidden="true" /><span>{point}</span></li>)}
                  </ul>
                  <div class="package-freebies">
                    <p>{packagesSection.freeIncluded}</p>
                    <ul>{item.freeFeatures.map((feature) => <li><CircleCheck class="h-4 w-4 shrink-0 text-moss" aria-hidden="true" /><span>{feature}</span></li>)}</ul>
                  </div>
                  <div class="package-tier-carousel" aria-label={`${item.name} package tiers`}>
                    <div class="package-tier-track">
                      {item.tiers.map((tier) => (
                        <div class={`package-tier ${tier.recommended ? "package-tier--featured" : ""}`}>
                          <div class="package-tier__top">
                            <span class="package-tier__name">{tier.name}</span>
                            {tier.recommended && <span class="package-tier__badge">{packagesSection.recommended}</span>}
                          </div>
                          <strong>{tier.price}</strong>
                          <p>{tier.scope}</p>
                          <small>{tier.meta}</small>
                        </div>
                      ))}
                    </div>
                    <div class="package-tier-dots" aria-hidden="true">
                      {item.tiers.map((tier, ti) => (
                        <button class={`package-tier-dot${ti === 0 ? " is-active" : ""}`} type="button" tabindex="-1"></button>
                      ))}
                    </div>
                  </div>
                  <p class="package-note">{item.note}</p>
                  <a href="#project-request" data-package={item.name} class="ui-button package-card__cta mt-5 inline-flex w-full items-center justify-center gap-2 rounded-full bg-ember px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#6f2119]">
                    {packagesSection.packageCta}
                    <ArrowRight class="h-4 w-4" aria-hidden="true" />
                  </a>
                </article>
              ))}
              <button class="pkg3d-btn" id="pkg3d-prev" aria-label="Pakej sebelumnya" type="button">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
              </button>
              <button class="pkg3d-btn" id="pkg3d-next" aria-label="Pakej seterusnya" type="button">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </button>
            </div>
            <div class="pkg3d-controls">
              <div class="pkg3d-dots" role="tablist" aria-label="Pilih pakej">
                {packages.map((item, i) => (
                  <button class={`pkg3d-dot${i === 0 ? " is-active" : ""}`} type="button" role="tab" aria-label={item.name}></button>
                ))}
              </div>
            </div>
          </div>
          <p class="package-footnote">{packagesSection.footnote}</p>
        </div>
      </section>

      <section id="process" class="process-section story-section relative overflow-hidden bg-mist px-5 py-20 sm:px-6 lg:px-8">
        <div class="light-rays-section-bg light-rays-section-bg--process" aria-hidden="true">
          <LightRays
            client:visible
            raysOrigin="left"
            raysColor="#176b4d"
            raysSpeed={2.3}
            lightSpread={1.55}
            rayLength={2.0}
            followMouse={true}
            mouseInfluence={0.34}
            noiseAmount={0.12}
            distortion={0.1}
            fadeDistance={2.2}
            saturation={1.0}
            pulsating={true}
          />
        </div>
        <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.86fr_1.14fr] lg:items-start">
          <div>
            <p class="topic-label text-moss">{processSection.kicker}</p>
            <h2 class="story-heading mt-4 text-4xl font-semibold tracking-normal text-ink sm:text-5xl">{processSection.title}</h2>
            <p class="mt-5 leading-8 text-ink/68">{processSection.body}</p>
          </div>
          <ProcessCardStack client:visible steps={processSection.steps} />
        </div>
      </section>

      <section id="faq" class="faq-section story-section px-5 py-20 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
          <div class="grid gap-10 lg:grid-cols-[0.72fr_1.28fr] lg:items-start">
            <div class="lg:sticky lg:top-28">
              <p class="topic-label text-ember">Soalan biasa</p>
              <h2 class="story-heading mt-4 text-4xl font-semibold tracking-normal text-ink sm:text-5xl">Perkara yang selalu ditanya sebelum menghubungi.</h2>
              <p class="mt-5 leading-8 text-ink/66">Kalau soalan anda tiada di sini, hantar terus melalui WhatsApp semasa mengisi form permintaan projek.</p>
            </div>
            <ul class="faq-list mt-2 bg-white">
              <li class="faq-item">
                <details>
                  <summary>Adakah saya perlu sediakan semua content sebelum menghubungi?</summary>
                  <p class="faq-answer">Tidak. Anda hanya perlu tahu apa yang bisnes anda buat dan siapa pelanggan sasaran. Kesediaan content adalah salah satu soalan dalam form permintaan, dan scope boleh disesuaikan untuk termasuk bantuan copywriting jika perlu.</p>
                </details>
              </li>
              <li class="faq-item">
                <details>
                  <summary>Apa yang berlaku selepas saya hantar permintaan melalui WhatsApp?</summary>
                  <p class="faq-answer">Anda akan terima balasan yang mengesahkan ringkasan scope, pakej yang dicadangkan, timeline, dan langkah seterusnya. Dari situ, kami bersetuju dengan scope, dan anda bayar deposit 50% untuk mula. Baki 50% dibayar sebelum launch.</p>
                </details>
              </li>
              <li class="faq-item">
                <details>
                  <summary>Adakah saya perlu uruskan hosting dan domain sendiri?</summary>
                  <p class="faq-answer">Ya. Anda perlu miliki domain dan akaun hosting sendiri. Jika belum ada, prosesnya mudah dan panduan disertakan. Ini memastikan anda kekal dalam kawalan website anda sendiri selepas launch.</p>
                </details>
              </li>
              <li class="faq-item">
                <details>
                  <summary>Berapa lama projek biasa mengambil masa?</summary>
                  <p class="faq-answer">Landing page Starter biasanya mengambil masa 3–10 hari bekerja bergantung pada tier. Business website memerlukan 7–18 hari bekerja. Custom build diskop secara berasingan. Timeline bermula selepas deposit dibayar dan content disediakan.</p>
                </details>
              </li>
              <li class="faq-item">
                <details>
                  <summary>Boleh saya minta perubahan selepas website dilancarkan?</summary>
                  <p class="faq-answer">Semakan termasuk dalam setiap pakej (1–3 bergantung pada tier), semuanya digunakan semasa proses bina. Perubahan selepas launch dikendalikan sebagai permintaan support berasingan dan dihargai mengikut scope.</p>
                </details>
              </li>
              <li class="faq-item">
                <details>
                  <summary>Adakah harga permulaan adalah harga muktamad?</summary>
                  <p class="faq-answer">Harga permulaan mencerminkan tier asas. Harga akhir bergantung pada jumlah halaman, kesediaan content, ciri tambahan, integrasi, keperluan copywriting, dan support launch. Pecahan penuh disahkan sebelum sebarang bayaran dibuat.</p>
                </details>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <section id="project-request" class="request-section story-section bg-paper px-5 py-20 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
          <div class="grid gap-8 lg:grid-cols-[0.68fr_1.32fr] lg:items-start">
            <div class="lg:sticky lg:top-28">
              <p class="topic-label text-ember">{request.kicker}</p>
              <h2 class="story-heading mt-4 text-4xl font-semibold tracking-normal text-ink sm:text-5xl">{request.title}</h2>
              <p class="mt-5 leading-8 text-ink/68">{request.body}</p>
            </div>

            <form id="project-request-form" data-whatsapp-number={whatsappNumber} data-form-copy={JSON.stringify(formCopy)} novalidate class="project-form-card rounded-2xl border border-line overflow-hidden">

              <!-- Step indicator -->
              <div class="form-steps-bar">
                <ol class="form-steps-track" aria-label="Kemajuan borang">
                  {["Bisnes", "Pakej", "Perincian", "Nota"].map((label, i) => (
                    <li class={`form-step-node${i === 0 ? " is-active" : ""}`} data-step-node={i}>
                      <span class="form-step-node__circle">{i + 1}</span>
                      <span class="form-step-node__label">{label}</span>
                    </li>
                  ))}
                </ol>
              </div>

              <!-- Step 1: Business -->
              <div class="form-step-panel is-active" data-step="0">
                <p class="form-step-heading">Ceritakan tentang bisnes anda.</p>
                <div class="space-y-6">
                  <label class="block"><span class="text-sm font-semibold text-ink">{formLabels.businessName}</span><input name="businessName" type="text" required autocomplete="organization" maxlength="120" class="mt-2 h-12 w-full rounded-lg border border-line bg-white px-4 text-ink outline-none transition focus:border-ember" placeholder={formLabels.businessNamePlaceholder} /></label>
                  <fieldset>
                    <legend class="text-sm font-semibold text-ink">{formLabels.websiteType}</legend>
                    <div class="mt-3 grid gap-3 md:grid-cols-3">
                      {websiteTypes.map((websiteType) => <label class="choice-card flex cursor-pointer gap-3 rounded-lg border border-line bg-paper p-4 transition focus-within:border-ember hover:border-ember"><input name="websiteType" type="radio" value={websiteType.name} required class="mt-1 h-4 w-4 accent-ember" /><span><span class="block font-semibold text-ink">{websiteType.name}</span><span class="mt-2 block text-sm leading-6 text-ink/64">{websiteType.detail}</span></span></label>)}
                    </div>
                  </fieldset>
                </div>
              </div>

              <!-- Step 2: Package -->
              <div class="form-step-panel" data-step="1">
                <p class="form-step-heading">Pilih pakej anda.</p>
                <div class="space-y-6">
                  <fieldset class="package-interest-block">
                    <legend class="text-sm font-semibold text-ink">{formLabels.packageInterest}</legend>
                    <div class="mt-3">
                      <label class="block">
                        <span class="sr-only">{formLabels.packageInterest}</span>
                        <select id="package-interest-select" name="packageInterest" required class="h-12 w-full rounded-lg border border-line bg-white px-4 text-ink outline-none transition focus:border-ember">
                          <option value="">{formLabels.packagePlaceholder}</option>
                          {packages.map((item) => <optgroup label={item.name} data-website-type={item.name}>{packageTierOptions.filter((option) => option.group === item.name).map((option) => <option value={option.value} data-summary={option.summary} data-meta={option.meta} data-free-features={option.freeFeatures}>{option.label}</option>)}</optgroup>)}
                        </select>
                        <div id="package-interest-summary" class="package-selected-summary" aria-live="polite"><p class="package-selected-summary__title">{formLabels.packageEmptyTitle}</p><p class="package-selected-summary__text">{formLabels.packageEmptyText}</p></div>
                      </label>
                    </div>
                  </fieldset>
                  <label class="block"><span class="text-sm font-semibold text-ink">{formLabels.businessType}</span><select name="businessType" required class="mt-2 h-12 w-full rounded-lg border border-line bg-white px-4 text-ink outline-none transition focus:border-ember"><option value="">{formLabels.businessTypePlaceholder}</option>{businessTypes.map((businessType) => <option>{businessType}</option>)}</select></label>
                  <fieldset>
                    <legend class="text-sm font-semibold text-ink">{formLabels.pages}</legend>
                    <div class="mt-3 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">{pageOptions.map((option) => <label class="choice-card request-check-card flex min-h-12 cursor-pointer items-center gap-3 rounded-lg border border-line bg-white px-4 text-sm font-semibold text-ink/76 transition hover:border-ember"><input name="pages" type="checkbox" value={option} class="h-4 w-4 shrink-0 accent-ember" /><span>{option}</span></label>)}</div>
                  </fieldset>
                  <fieldset>
                    <legend class="text-sm font-semibold text-ink">{formLabels.features}</legend>
                    <div class="mt-3 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">{featureOptions.map((option) => <label class="choice-card request-check-card flex min-h-12 cursor-pointer items-center gap-3 rounded-lg border border-line bg-white px-4 text-sm font-semibold text-ink/76 transition hover:border-ember"><input name="features" type="checkbox" value={option} class="h-4 w-4 shrink-0 accent-ember" /><span>{option}</span></label>)}</div>
                  </fieldset>
                </div>
              </div>

              <!-- Step 3: Details -->
              <div class="form-step-panel" data-step="2">
                <p class="form-step-heading">Beberapa perincian lagi.</p>
                <div class="space-y-6">
                  <div class="grid gap-4 md:grid-cols-2">
                    <label class="block"><span class="text-sm font-semibold text-ink">{formLabels.timeline}</span><select name="timeline" required class="mt-2 h-12 w-full rounded-lg border border-line bg-white px-4 text-ink outline-none transition focus:border-ember"><option value="">{formLabels.timelinePlaceholder}</option>{timelineOptions.map((option) => <option>{option}</option>)}</select></label>
                    <label class="block"><span class="text-sm font-semibold text-ink">{formLabels.budget}</span><select name="budget" class="mt-2 h-12 w-full rounded-lg border border-line bg-white px-4 text-ink outline-none transition focus:border-ember"><option value="">{formLabels.budgetPlaceholder}</option>{budgetOptions.map((option) => <option>{option}</option>)}</select></label>
                  </div>
                  <fieldset>
                    <legend class="text-sm font-semibold text-ink">{formLabels.domain}</legend>
                    <div class="mt-3 grid gap-3 md:grid-cols-2">{domainOwnershipOptions.map((option) => <label class="choice-card flex cursor-pointer gap-3 rounded-lg border border-line bg-paper p-4 text-sm font-semibold text-ink/76 transition hover:border-ember"><input name="domainStatus" type="radio" value={option} required class="mt-0.5 h-4 w-4 accent-ember" /><span>{option}</span></label>)}</div>
                  </fieldset>
                  <fieldset>
                    <legend class="text-sm font-semibold text-ink">{formLabels.contentReadiness}</legend>
                    <div class="mt-3 grid gap-3 md:grid-cols-2">{contentReadinessOptions.map((option) => <label class="choice-card flex cursor-pointer gap-3 rounded-lg border border-line bg-paper p-4 text-sm font-semibold text-ink/76 transition hover:border-ember"><input name="contentReadiness" type="radio" value={option} required class="mt-0.5 h-4 w-4 accent-ember" /><span>{option}</span></label>)}</div>
                  </fieldset>
                  <div class="grid gap-4 md:grid-cols-2">
                    <label class="block"><span class="text-sm font-semibold text-ink">{formLabels.currentPresence}</span><input name="currentPresence" type="text" autocomplete="url" maxlength="200" class="mt-2 h-12 w-full rounded-lg border border-line bg-white px-4 text-ink outline-none transition focus:border-ember" placeholder={formLabels.currentPresencePlaceholder} /></label>
                    <label class="block"><span class="text-sm font-semibold text-ink">{formLabels.mainGoal}</span><input name="mainGoal" type="text" autocomplete="off" maxlength="200" class="mt-2 h-12 w-full rounded-lg border border-line bg-white px-4 text-ink outline-none transition focus:border-ember" placeholder={formLabels.mainGoalPlaceholder} /></label>
                  </div>
                </div>
              </div>

              <!-- Step 4: Notes + Submit -->
              <div class="form-step-panel" data-step="3">
                <p class="form-step-heading">Ada sesuatu yang penting?</p>
                <div class="space-y-6">
                  <label class="block"><span class="text-sm font-semibold text-ink">{formLabels.projectNotes}</span><textarea name="projectNotes" rows="5" autocomplete="off" maxlength="1200" class="mt-2 w-full rounded-lg border border-line bg-white px-4 py-3 text-ink outline-none transition focus:border-ember" placeholder={formLabels.projectNotesPlaceholder}></textarea></label>
                  <div class="submit-panel flex flex-col gap-4 rounded-lg border border-line bg-paper p-5 md:flex-row md:items-center md:justify-between">
                    <div class="space-y-2"><p id="project-request-status" class="leading-7 text-ink/68">{request.defaultStatus}</p><p class="text-sm leading-6 text-ink/58">{request.contactNote}</p><p class="text-sm leading-6"><a href="/privacy/" class="font-semibold text-ember transition hover:text-ink">{request.privacy}</a></p></div>
                    <button id="project-request-submit" type="submit" class="ui-button submit-button inline-flex min-h-12 min-w-44 items-center justify-center gap-2 whitespace-nowrap rounded-full bg-ember px-6 text-base font-semibold text-white transition hover:bg-[#6f2119]"><MessageCircle class="submit-icon h-5 w-5" aria-hidden="true" /><span class="submit-label">{request.submit}</span></button>
                  </div>
                  <p class="mt-4 text-center text-sm text-ink/58">Belum bersedia isi borang? <a href={`https://wa.me/${whatsappNumber.replace(/\D/g,"")}?text=${encodeURIComponent("Hai, saya ingin buat konsultasi ringkas sebelum hantar permintaan projek.")}`} target="_blank" rel="noopener noreferrer" class="font-semibold text-ember transition hover:text-ink">Tempah konsultasi percuma →</a></p>
                </div>
              </div>

              <!-- Step navigation -->
              <div class="form-step-nav">
                <button type="button" id="form-step-back" class="form-step-nav__back">← Kembali</button>
                <button type="button" id="form-step-next" class="form-step-nav__next">Seterusnya →</button>
              </div>

            </form>
          </div>
        </div>
      </section>
    </main>

    <a href="#project-request" class="floating-wa" id="floating-wa-btn" aria-label="Hantar permintaan projek">
      <svg class="floating-wa__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.285 7.041L.787 23.41a.75.75 0 0 0 .916.916l4.37-1.498A11.954 11.954 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.716 9.716 0 0 1-4.94-1.348l-.355-.21-3.676 1.26 1.26-3.676-.21-.355A9.716 9.716 0 0 1 2.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/></svg>
      Minta projek
    </a>
    <script>
      (() => {
        const btn = document.getElementById('floating-wa-btn');
        if (!btn) return;
        const hero = document.querySelector('main > section:first-child');
        if (!hero) return;
        const observer = new IntersectionObserver(
          ([entry]) => btn.classList.toggle('is-visible', !entry.isIntersecting),
          { threshold: 0.1 }
        );
        observer.observe(hero);
      })();
    </script>

    <footer class="site-footer border-t border-line bg-paper px-5 py-8 sm:px-6 lg:px-8">
      <div class="mx-auto grid max-w-6xl gap-6 text-sm text-ink/62 md:grid-cols-[1fr_auto] md:items-center">
        <div class="site-footer__brand"><a href="#top" class="site-footer__logo" aria-label="Mavora Digital home"><img src="/logo-transparent.png" alt="Mavora Digital" class="h-auto w-full object-contain" width="980" height="313" loading="lazy" /></a><p>{footer.body}</p></div>
        <div class="site-footer__actions"><nav class="site-footer__links" aria-label="Navigasi footer"><a href={ctaHref}>{footer.projectRequest}</a><a href="/privacy/">{footer.privacy}</a></nav><p>{footer.note}</p></div>
      </div>
    </footer>

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const header = document.querySelector<HTMLElement>("#site-header");
      let lastScrollY = window.scrollY;
      let headerTicking = false;

      const updateHeader = () => {
        if (!header) return;
        const currentScrollY = window.scrollY;
        header.classList.toggle("is-scrolled", currentScrollY > 24);
        header.classList.toggle("is-hidden", currentScrollY > lastScrollY && currentScrollY > 140);
        lastScrollY = currentScrollY;
        headerTicking = false;
      };

      window.addEventListener(
        "scroll",
        () => {
          if (!headerTicking) {
            window.requestAnimationFrame(updateHeader);
            headerTicking = true;
          }
        },
        { passive: true },
      );

      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const revealTargets = Array.from(document.querySelectorAll<HTMLElement>("main > section:not(:first-child), form"));
      const storySections = Array.from(document.querySelectorAll<HTMLElement>(".story-section"));
      const studioStatementEl = document.querySelector<HTMLElement>(".studio-statement");
      const heroMedia = document.querySelector<HTMLElement>(".hero-media");
      const storyLine = document.querySelector<SVGElement>(".story-line");

      if (!prefersReducedMotion) {
        gsap.timeline({ defaults: { ease: "power3.out" } })
          .fromTo(".hero-kicker", { y: 18, autoAlpha: 0 }, { y: 0, autoAlpha: 1, duration: 0.52 })
          .fromTo(".hero-word", { y: 34, rotateX: 48, scale: 0.94, autoAlpha: 0, transformOrigin: "left bottom" }, { y: 0, rotateX: 0, scale: 1, autoAlpha: 1, duration: 0.72, stagger: 0.055 }, "<0.12")
          .fromTo(".hero-copy", { y: 18, autoAlpha: 0 }, { y: 0, autoAlpha: 1, duration: 0.58 }, ">-0.02")
          .fromTo(".hero-proof-line", { y: 14, autoAlpha: 0 }, { y: 0, autoAlpha: 1, duration: 0.48 }, "<0.16")
          .fromTo(".hero-actions", { y: 18, autoAlpha: 0 }, { y: 0, autoAlpha: 1, duration: 0.58 }, "<0.14");

        if (heroMedia) {
          gsap.fromTo(heroMedia, { scale: 1.09, y: 18 }, { scale: 1.035, y: 42, ease: "none", scrollTrigger: { trigger: "#top", start: "top top", end: "bottom top", scrub: true } });
        }

        revealTargets.forEach((target, index) => {
          gsap.fromTo(
            target,
            { y: 56, scale: 0.96, opacity: 0 },
            {
              y: 0,
              scale: 1,
              opacity: 1,
              duration: 0.72,
              delay: Math.min(index % 4, 3) * 0.05,
              ease: "power3.out",
              scrollTrigger: { trigger: target, start: "top 88%", once: true },
              onComplete: () => target.classList.add("is-visible"),
            },
          );
        });

        storySections.forEach((section) => {
          gsap.fromTo(
            section,
            { "--story-progress": 0 },
            { "--story-progress": 1, ease: "none", scrollTrigger: { trigger: section, start: "top 88%", end: "bottom 42%", scrub: true } },
          );
        });

        if (studioStatementEl) {
          const studioItems = studioStatementEl.querySelectorAll<HTMLElement>(".studio-motion, .studio-principles li");
          gsap.fromTo(
            studioItems,
            { y: 34, opacity: 0, filter: "blur(8px)" },
            {
              y: 0,
              opacity: 1,
              filter: "blur(0px)",
              duration: 0.78,
              stagger: 0.09,
              ease: "power3.out",
              scrollTrigger: { trigger: studioStatementEl, start: "top 72%", once: true },
            },
          );
        }

        if (storyLine) {
          const path = storyLine.querySelector("path");
          if (path) {
            gsap.fromTo(path, { strokeDashoffset: 940 }, { strokeDashoffset: 0, duration: 1.2, ease: "power3.out", scrollTrigger: { trigger: storyLine, start: "top 82%", once: true } });
          }
        }
      }

      if (studioStatementEl && !prefersReducedMotion && window.matchMedia("(hover: hover) and (pointer: fine)").matches) {
        studioStatementEl.addEventListener("pointermove", (event) => {
          const rect = studioStatementEl.getBoundingClientRect();
          const x = ((event.clientX - rect.left) / rect.width) * 100;
          const y = ((event.clientY - rect.top) / rect.height) * 100;
          studioStatementEl.style.setProperty("--studio-x", `${x}%`);
          studioStatementEl.style.setProperty("--studio-y", `${y}%`);
          studioStatementEl.classList.add("is-pointer-active");
        });

        studioStatementEl.addEventListener("pointerleave", () => {
          studioStatementEl.classList.remove("is-pointer-active");
        });
      }

      const canUsePointerTilt = window.matchMedia("(hover: hover) and (pointer: fine) and (prefers-reduced-motion: no-preference)").matches;

      if (canUsePointerTilt) {
        document.querySelectorAll<HTMLElement>(".ui-button").forEach((button) => {
          button.addEventListener("pointerenter", () => gsap.to(button, { y: -2, duration: 0.18, ease: "power2.out" }));
          button.addEventListener("pointerleave", () => gsap.to(button, { y: 0, scale: 1, duration: 0.22, ease: "power2.out" }));
          button.addEventListener("pointerdown", () => gsap.to(button, { scale: 0.98, duration: 0.08, ease: "power2.out" }));
          button.addEventListener("pointerup", () => gsap.to(button, { scale: 1, duration: 0.16, ease: "back.out(1.8)" }));
        });

        document.querySelectorAll<HTMLElement>(".tilt-card").forEach((card) => {
          card.addEventListener("pointermove", (event) => {
            const rect = card.getBoundingClientRect();
            const x = (event.clientX - rect.left) / rect.width;
            const y = (event.clientY - rect.top) / rect.height;
            card.style.setProperty("--tilt-x", `${x * 100}%`);
            card.style.setProperty("--tilt-y", `${y * 100}%`);
            gsap.to(card, { y: -4, rotateX: (0.5 - y) * 7, rotateY: (x - 0.5) * 9, transformPerspective: 900, duration: 0.22, ease: "power2.out", overwrite: true });
          });

          card.addEventListener("pointerleave", () => {
            card.style.removeProperty("--tilt-x");
            card.style.removeProperty("--tilt-y");
            gsap.to(card, { y: 0, rotateX: 0, rotateY: 0, duration: 0.34, ease: "elastic.out(1, 0.55)", overwrite: true });
          });
        });
      }

      document.addEventListener("click", (event) => {
        const link = (event.target as Element | null)?.closest<HTMLAnchorElement>("a[href]");
        if (!link || event.defaultPrevented || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

        const url = new URL(link.href, window.location.href);
        const isSamePageHash = url.pathname === window.location.pathname && url.hash;
        const isExternal = url.origin !== window.location.origin;

        if (link.target || link.hasAttribute("download") || isExternal || isSamePageHash) return;

        event.preventDefault();
        gsap.to(document.body, { opacity: 0.88, scale: 0.992, duration: 0.18, ease: "power2.inOut" });
        document.body.classList.add("page-exit");
        window.setTimeout(() => {
          window.location.href = url.href;
        }, 180);
      });

      const form = document.querySelector<HTMLFormElement>("#project-request-form");
      const status = document.querySelector<HTMLElement>("#project-request-status");
      const submitButton = document.querySelector<HTMLButtonElement>("#project-request-submit");
      const submitLabel = submitButton?.querySelector<HTMLElement>(".submit-label") || null;
      const packageSelect = document.querySelector<HTMLSelectElement>("#package-interest-select");
      const packageSummary = document.querySelector<HTMLElement>("#package-interest-summary");
      const copy = JSON.parse(form?.dataset.formCopy || "{}");
      const requestCopy = copy.request || {};
      const labels = copy.formLabels || {};
      const packageFallbacks = copy.packageFallbacks || {};

      const resetSubmitButton = () => {
        submitButton?.classList.remove("is-loading", "is-success");
        if (submitLabel) submitLabel.textContent = requestCopy.submit || "Hantar ke WhatsApp";
      };

      const updatePackageSummary = () => {
        if (!packageSelect) return;
        const selectedOption = packageSelect.selectedOptions[0];
        if (!packageSummary || !selectedOption?.value) {
          if (packageSummary) {
            packageSummary.innerHTML = `<p class="package-selected-summary__title">${packageFallbacks.title || "Pilih pakej untuk preview asas projek."}</p><p class="package-selected-summary__text">${packageFallbacks.text || "Harga akhir masih boleh dilaras selepas semakan."}</p>`;
          }
          return;
        }
        packageSummary.innerHTML = [
          `<p class="package-selected-summary__title">${selectedOption.value}</p>`,
          `<p class="package-selected-summary__text">${selectedOption.dataset.summary || packageFallbacks.scope || "Scope akan disahkan"}</p>`,
          `<p class="package-selected-summary__meta">${selectedOption.dataset.meta || packageFallbacks.timeline || "Timeline akan disahkan"}</p>`,
          `<p class="package-selected-summary__free">Termasuk percuma: ${selectedOption.dataset.freeFeatures || packageFallbacks.free || "Disahkan selepas semakan scope"}</p>`,
        ].join("");
      };

      packageSelect?.addEventListener("change", () => {
        updatePackageSummary();
        // Reverse-sync: auto-select the matching website type radio
        const selectedOpt = packageSelect?.selectedOptions[0];
        const group = selectedOpt?.closest("optgroup") as HTMLOptGroupElement | null;
        const groupType = group?.dataset.websiteType;
        if (groupType) {
          const groupToWebsiteType: Record<string, string> = {
            "Starter Website": "Landing Page",
            "Business Website": "Business Website",
            "Custom Build": "Custom Website",
          };
          const radioValue = groupToWebsiteType[groupType];
          const radio = document.querySelector<HTMLInputElement>(`input[name="websiteType"][value="${radioValue}"]`);
          if (radio && !radio.checked) {
            radio.checked = true;
            radio.dispatchEvent(new Event("change", { bubbles: true }));
          }
        }
      });

      // Filter package options based on selected website type
      const websiteTypeToGroup: Record<string, string> = {
        "Landing Page": "Starter Website",
        "Business Website": "Business Website",
        "Custom Website": "Custom Build",
      };

      const filterPackagesByWebsiteType = (websiteType: string) => {
        if (!packageSelect) return;
        const targetGroup = websiteTypeToGroup[websiteType];
        const optgroups = packageSelect.querySelectorAll<HTMLOptGroupElement>("optgroup");

        optgroups.forEach((group) => {
          const matches = !targetGroup || group.dataset.websiteType === targetGroup;
          Array.from(group.querySelectorAll("option")).forEach((opt) => {
            opt.hidden = !matches;
            opt.disabled = !matches;
          });
          group.hidden = !matches;
        });

        const currentOption = packageSelect.selectedOptions[0];
        if (currentOption?.hidden) {
          packageSelect.value = "";
          updatePackageSummary();
        }
      };

      document.querySelectorAll<HTMLInputElement>('input[name="websiteType"]').forEach((radio) => {
        radio.addEventListener("change", () => {
          if (radio.checked) filterPackagesByWebsiteType(radio.value);
        });
      });

      const checkedType = document.querySelector<HTMLInputElement>('input[name="websiteType"]:checked');
      if (checkedType) filterPackagesByWebsiteType(checkedType.value);

      document.querySelectorAll<HTMLAnchorElement>("a[data-package]").forEach((cta) => {
        cta.addEventListener("click", () => {
          const pkg = cta.dataset.package;
          if (!packageSelect || !pkg) return;
          const match = Array.from(packageSelect.options).find((o) => o.value.startsWith(pkg));
          if (match?.value) {
            packageSelect.value = match.value;
            updatePackageSummary();
          }
        });
      });

      form?.addEventListener("submit", (event) => {
        event.preventDefault();
        submitButton?.classList.remove("is-success");
        submitButton?.classList.add("is-loading");
        if (submitButton && !prefersReducedMotion) gsap.to(submitButton, { scale: 0.98, duration: 0.12, ease: "power2.out" });
        if (submitLabel) submitLabel.textContent = requestCopy.loading || "Menyediakan...";

        const formData = new FormData(form);
        const value = (name: string) => String(formData.get(name) || "Tidak diberikan");
        const list = (name: string) => {
          const values = formData.getAll(name).map((item) => String(item));
          return values.length > 0 ? values.join(", ") : "Tidak dipilih";
        };
        const body = [
          "Permintaan projek website",
          "",
          `${labels.businessName || "Nama bisnes"}: ${value("businessName")}`,
          `${labels.websiteType || "Jenis website"}: ${value("websiteType")}`,
          `${labels.packageInterest || "Pakej diminati"}: ${value("packageInterest")}`,
          `${labels.businessType || "Jenis bisnes"}: ${value("businessType")}`,
          `${labels.timeline || "Timeline"}: ${value("timeline")}`,
          `${labels.budget || "Fleksibiliti bajet"}: ${value("budget")}`,
          `Status domain: ${value("domainStatus")}`,
          `Halaman/section: ${list("pages")}`,
          `Ciri/setup: ${list("features")}`,
          `${labels.contentReadiness || "Kesediaan content"}: ${value("contentReadiness")}`,
          `${labels.currentPresence || "Website atau social sekarang"}: ${value("currentPresence")}`,
          `${labels.mainGoal || "Matlamat utama website"}: ${value("mainGoal")}`,
          "",
          "Perkara penting:",
          value("projectNotes"),
        ].join("\n");
        const whatsappNumber = (form.dataset.whatsappNumber || "").replace(/\D/g, "");
        if (!whatsappNumber) {
          if (status) status.textContent = requestCopy.missingNumberStatus || "Nombor WhatsApp belum dikonfigurasi.";
          resetSubmitButton();
          return;
        }
        if (status) status.textContent = requestCopy.successStatus || "Mesej WhatsApp sudah disediakan.";
        submitButton?.classList.remove("is-loading");
        submitButton?.classList.add("is-success");
        if (submitButton && !prefersReducedMotion) gsap.to(submitButton, { scale: 1, duration: 0.28, ease: "back.out(1.8)" });
        if (submitLabel) submitLabel.textContent = requestCopy.success || "Sedia di WhatsApp";
        window.setTimeout(() => {
          window.location.href = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(body)}`;
        }, 180);
      });

      // Multi-step form wizard
      (() => {
        const panels = Array.from(document.querySelectorAll<HTMLElement>(".form-step-panel"));
        const nodes = Array.from(document.querySelectorAll<HTMLElement>(".form-step-node"));
        const backBtn = document.getElementById("form-step-back") as HTMLButtonElement | null;
        const nextBtn = document.getElementById("form-step-next") as HTMLButtonElement | null;
        const navBar = document.querySelector<HTMLElement>(".form-step-nav");
        let step = 0;

        const show = (i: number) => {
          panels.forEach((p, idx) => p.classList.toggle("is-active", idx === i));
          nodes.forEach((n, idx) => {
            n.classList.toggle("is-active", idx === i);
            n.classList.toggle("is-done", idx < i);
          });
          if (backBtn) backBtn.style.visibility = i === 0 ? "hidden" : "visible";
          const isLast = i === panels.length - 1;
          if (navBar) navBar.style.display = isLast ? "none" : "flex";
          step = i;
        };

        const validate = (i: number): boolean => {
          const panel = panels[i];
          const required = Array.from(panel.querySelectorAll<HTMLInputElement | HTMLSelectElement>("[required]"));
          const radioNames = new Set(required.filter(el => (el as HTMLInputElement).type === "radio").map(el => el.name));
          let ok = true;
          let firstBad: HTMLElement | null = null;

          required.forEach(el => {
            if ((el as HTMLInputElement).type === "radio") return;
            if (!el.value.trim()) { ok = false; if (!firstBad) firstBad = el as HTMLElement; }
          });
          radioNames.forEach(name => {
            if (!panel.querySelector<HTMLInputElement>(`input[name="${name}"]:checked`)) ok = false;
          });

          if (!ok) {
            if (firstBad) (firstBad as HTMLElement).focus();
            nextBtn?.classList.add("is-error");
            setTimeout(() => nextBtn?.classList.remove("is-error"), 500);
          }
          return ok;
        };

        nextBtn?.addEventListener("click", () => { if (validate(step)) show(step + 1); });
        backBtn?.addEventListener("click", () => { if (step > 0) show(step - 1); });

        show(0);
      })();

      // 3D Package Carousel
      const pkg3dScene = document.getElementById("pkg3d-scene");
      if (pkg3dScene) {
        const pkg3dCards = Array.from(pkg3dScene.querySelectorAll<HTMLElement>(".pkg3d-card"));
        const pkg3dDots = Array.from(document.querySelectorAll<HTMLButtonElement>(".pkg3d-dot"));
        const pkg3dN = pkg3dCards.length;
        let pkg3dActive = 0;
        const pkg3dSyncHeight = () => {
          let maxH = 0;
          pkg3dCards.forEach(c => { const h = c.offsetHeight; if (h > maxH) maxH = h; });
          if (maxH > 0) { pkg3dScene.style.minHeight = maxH + "px"; pkg3dScene.style.height = maxH + "px"; }
        };
        const pkg3dRender = () => {
          pkg3dCards.forEach((card, i) => {
            const offset = ((i - pkg3dActive) % pkg3dN + pkg3dN) % pkg3dN;
            card.classList.remove("is-center", "is-left", "is-right");
            if (offset === 0) card.classList.add("is-center");
            else if (offset === 1) card.classList.add("is-right");
            else card.classList.add("is-left");
          });
          pkg3dDots.forEach((d, i) => d.classList.toggle("is-active", i === pkg3dActive));
        };
        // Auto-rotate
        let pkg3dAuto: ReturnType<typeof setInterval> | null = null;
        let pkg3dUserActed = false;
        const pkg3dStartAuto = () => { if (!pkg3dUserActed) { pkg3dAuto = setInterval(() => { pkg3dActive = (pkg3dActive + 1) % pkg3dN; pkg3dRender(); }, 3000); } };
        const pkg3dStopAuto = () => { if (pkg3dAuto !== null) { clearInterval(pkg3dAuto); pkg3dAuto = null; } };
        const pkg3dHandleInteract = () => { pkg3dUserActed = true; pkg3dStopAuto(); };
        pkg3dCards.forEach((card, i) => {
          card.addEventListener("click", (e) => {
            if (!card.classList.contains("is-center")) {
              e.preventDefault();
              pkg3dActive = i;
              pkg3dRender();
              pkg3dHandleInteract();
            }
          });
        });
        document.getElementById("pkg3d-prev")?.addEventListener("click", () => {
          pkg3dActive = (pkg3dActive - 1 + pkg3dN) % pkg3dN;
          pkg3dRender();
          pkg3dHandleInteract();
        });
        document.getElementById("pkg3d-next")?.addEventListener("click", () => {
          pkg3dActive = (pkg3dActive + 1) % pkg3dN;
          pkg3dRender();
          pkg3dHandleInteract();
        });
        pkg3dDots.forEach((dot, i) => {
          dot.addEventListener("click", () => { pkg3dActive = i; pkg3dRender(); pkg3dHandleInteract(); });
        });
        let pkg3dTouchX = 0;
        pkg3dScene.addEventListener("touchstart", (e) => { pkg3dTouchX = e.touches[0].clientX; }, { passive: true });
        pkg3dScene.addEventListener("touchend", (e) => {
          const dx = e.changedTouches[0].clientX - pkg3dTouchX;
          if (Math.abs(dx) > 40) {
            pkg3dActive = dx < 0 ? (pkg3dActive + 1) % pkg3dN : (pkg3dActive - 1 + pkg3dN) % pkg3dN;
            pkg3dRender();
            pkg3dHandleInteract();
          }
        }, { passive: true });
        const pkg3dStage = pkg3dScene.closest<HTMLElement>(".pkg3d-stage");
        if (pkg3dStage) {
          pkg3dStage.addEventListener("mouseenter", pkg3dStopAuto);
          pkg3dStage.addEventListener("mouseleave", pkg3dStartAuto);
        }
        const pkg3dRO = new ResizeObserver(pkg3dSyncHeight);
        pkg3dCards.forEach(c => pkg3dRO.observe(c));
        pkg3dRender();
        pkg3dStartAuto();
        window.addEventListener("load", pkg3dSyncHeight, { once: true });
      }

      // 3D Service Carousel
      const svc3dScene = document.getElementById("svc3d-scene");
      if (svc3dScene) {
        const svc3dCards = Array.from(svc3dScene.querySelectorAll<HTMLElement>(".svc3d-card"));
        const svc3dDots = Array.from(document.querySelectorAll<HTMLButtonElement>(".svc3d-dot"));
        const svc3dN = svc3dCards.length;
        let svc3dActive = 0;
        const svc3dSyncHeight = () => {
          let maxH = 0;
          svc3dCards.forEach(c => { const h = c.offsetHeight; if (h > maxH) maxH = h; });
          if (maxH > 0) { svc3dScene.style.minHeight = maxH + "px"; svc3dScene.style.height = maxH + "px"; }
        };
        const svc3dRender = () => {
          svc3dCards.forEach((card, i) => {
            const offset = ((i - svc3dActive) % svc3dN + svc3dN) % svc3dN;
            card.classList.remove("is-center", "is-left", "is-right");
            if (offset === 0) card.classList.add("is-center");
            else if (offset === 1) card.classList.add("is-right");
            else card.classList.add("is-left");
          });
          svc3dDots.forEach((d, i) => d.classList.toggle("is-active", i === svc3dActive));
        };
        let svc3dAuto: ReturnType<typeof setInterval> | null = null;
        let svc3dUserActed = false;
        const svc3dStartAuto = () => { if (!svc3dUserActed) { svc3dAuto = setInterval(() => { svc3dActive = (svc3dActive + 1) % svc3dN; svc3dRender(); }, 3200); } };
        const svc3dStopAuto = () => { if (svc3dAuto !== null) { clearInterval(svc3dAuto); svc3dAuto = null; } };
        const svc3dHandleInteract = () => { svc3dUserActed = true; svc3dStopAuto(); };
        svc3dCards.forEach((card, i) => {
          card.addEventListener("click", () => {
            if (!card.classList.contains("is-center")) {
              svc3dActive = i;
              svc3dRender();
              svc3dHandleInteract();
            }
          });
        });
        document.getElementById("svc3d-prev")?.addEventListener("click", () => {
          svc3dActive = (svc3dActive - 1 + svc3dN) % svc3dN;
          svc3dRender();
          svc3dHandleInteract();
        });
        document.getElementById("svc3d-next")?.addEventListener("click", () => {
          svc3dActive = (svc3dActive + 1) % svc3dN;
          svc3dRender();
          svc3dHandleInteract();
        });
        svc3dDots.forEach((dot, i) => {
          dot.addEventListener("click", () => { svc3dActive = i; svc3dRender(); svc3dHandleInteract(); });
        });
        let svc3dTouchX = 0;
        svc3dScene.addEventListener("touchstart", (e) => { svc3dTouchX = e.touches[0].clientX; }, { passive: true });
        svc3dScene.addEventListener("touchend", (e) => {
          const dx = e.changedTouches[0].clientX - svc3dTouchX;
          if (Math.abs(dx) > 40) {
            svc3dActive = dx < 0 ? (svc3dActive + 1) % svc3dN : (svc3dActive - 1 + svc3dN) % svc3dN;
            svc3dRender();
            svc3dHandleInteract();
          }
        }, { passive: true });
        const svc3dStage = svc3dScene.closest<HTMLElement>(".svc3d-stage");
        if (svc3dStage) {
          svc3dStage.addEventListener("mouseenter", svc3dStopAuto);
          svc3dStage.addEventListener("mouseleave", svc3dStartAuto);
        }
        const svc3dRO = new ResizeObserver(svc3dSyncHeight);
        svc3dCards.forEach(c => svc3dRO.observe(c));
        svc3dRender();
        svc3dStartAuto();
        window.addEventListener("load", svc3dSyncHeight, { once: true });
      }

      // Portfolio slider
      const pfSlider = document.getElementById("pf-slider");
      if (pfSlider) {
        document.getElementById("pf-next")?.addEventListener("click", () => {
          const items = pfSlider.querySelectorAll(".pf-item");
          pfSlider.append(items[0]);
        });
        document.getElementById("pf-prev")?.addEventListener("click", () => {
          const items = pfSlider.querySelectorAll(".pf-item");
          pfSlider.prepend(items[items.length - 1]);
        });
      }

      // Tier carousels
      document.querySelectorAll<HTMLElement>(".package-tier-carousel").forEach((carousel) => {
        const track = carousel.querySelector<HTMLElement>(".package-tier-track");
        const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>(".package-tier-dot"));
        if (!track || !dots.length) return;
        const updateDots = () => {
          const idx = Math.round(track.scrollLeft / track.offsetWidth);
          dots.forEach((d, i) => d.classList.toggle("is-active", i === idx));
        };
        dots.forEach((dot, i) => {
          dot.addEventListener("click", () => track.scrollTo({ left: i * track.offsetWidth, behavior: "smooth" }));
        });
        track.addEventListener("scroll", updateDots, { passive: true });
        updateDots();
      });
    </script>
  </body>
</html>
