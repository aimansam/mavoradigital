---
import "../styles/global.css";
import { ArrowLeft, ShieldCheck } from "@lucide/astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#fbf7ef" />
    <meta name="description" content="How Mavora Digital handles website request details submitted through the landing page." />
    <link rel="canonical" href="https://mavoradigital.com/privacy/" />
    <meta name="robots" content="noindex" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://mavoradigital.com/privacy/" />
    <meta property="og:title" content="Privacy | Mavora Digital" />
    <meta property="og:description" content="How Mavora Digital handles website request details submitted through the landing page." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700&family=Poppins:wght@500;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" href="/logo-transparent.png" />
    <title>Privacy | Mavora Digital</title>
  </head>
  <body class="bg-paper text-ink antialiased">
    <main class="px-5 py-8 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <a href="/#project-request" class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-ink shadow-[0_8px_20px_rgba(17,24,39,0.06)] transition hover:text-ember">
          <ArrowLeft class="h-4 w-4" aria-hidden="true" />
          Back to request form
        </a>

        <section class="mt-8 rounded-lg border border-line bg-white p-6 shadow-[0_10px_28px_rgba(17,24,39,0.06)] sm:p-8 lg:p-10">
          <div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-mist text-moss">
            <ShieldCheck class="h-6 w-6" aria-hidden="true" />
          </div>
          <p class="topic-label mt-7 text-ember">Privacy</p>
          <h1 class="mt-3 text-4xl font-semibold tracking-normal text-ink sm:text-5xl">Your request details stay focused on your website project.</h1>
          <p class="mt-5 max-w-2xl leading-8 text-ink/68">
            Mavora Digital only uses the details you submit to understand your website request, reply to you, and prepare the next project conversation.
          </p>

          <div class="mt-10 grid gap-5 md:grid-cols-2">
            <section class="rounded-lg border border-line bg-paper p-5">
              <h2 class="text-xl font-semibold text-ink">What is collected</h2>
              <p class="mt-3 leading-7 text-ink/66">The request form can include your name, business name, email, phone, website needs, domain status, timeline, content readiness, and project notes.</p>
            </section>
            <section class="rounded-lg border border-line bg-paper p-5">
              <h2 class="text-xl font-semibold text-ink">How it is used</h2>
              <p class="mt-3 leading-7 text-ink/66">The information is used to respond to your inquiry, discuss scope, and plan the best next step for your website.</p>
            </section>
            <section class="rounded-lg border border-line bg-paper p-5">
              <h2 class="text-xl font-semibold text-ink">Where it goes</h2>
              <p class="mt-3 leading-7 text-ink/66">Submitting the form opens WhatsApp with your answers prepared as a message. The message is only sent when you send it in WhatsApp.</p>
            </section>
            <section class="rounded-lg border border-line bg-paper p-5">
              <h2 class="text-xl font-semibold text-ink">What is not done</h2>
              <p class="mt-3 leading-7 text-ink/66">Mavora Digital does not sell request details, publish private project notes, or use submitted contact details for unrelated marketing lists.</p>
            </section>
          </div>

          <div class="mt-8 rounded-lg border border-line bg-mist p-5">
            <h2 class="text-xl font-semibold text-ink">Questions or updates</h2>
            <p class="mt-3 leading-7 text-ink/66">If any submitted detail needs to be corrected or removed, send a follow-up message through the same WhatsApp conversation.</p>
          </div>
        </section>
      </div>
    </main>
  </body>
</html>