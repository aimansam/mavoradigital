    <footer class="site-footer border-t border-line bg-paper px-5 py-8 sm:px-6 lg:px-8">
      <div class="mx-auto grid max-w-6xl gap-6 text-sm text-ink/62 md:grid-cols-[1fr_auto] md:items-center">
