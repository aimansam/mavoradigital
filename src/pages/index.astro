                  <p class="text-center text-sm text-ink/58">Not ready to fill the form yet? <a href={`https://wa.me/${whatsappNumber.replace(/\D/g,"")}?text=${encodeURIComponent("Hi, I'd like to book a quick consultation before submitting a project request.")}`} target="_blank" rel="noopener noreferrer" class="font-semibold text-ember transition hover:text-ink">Book a free consultation →</a></p>
                </div>
              </div>

              <!-- Step navigation -->
              <div class="form-step-nav">
                <button type="button" id="form-step-back" class="form-step-nav__back">← Back</button>
                <button type="button" id="form-step-next" class="form-step-nav__next">Next →</button>
              </div>

            </form>
          </div>
        </div>
      </section>
    </main>

