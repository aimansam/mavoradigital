---
import "../styles/global.css";
import { ArrowRight, CircleCheck, MessageCircle, PanelsTopLeft, Sparkles, Wrench } from "@lucide/astro";
import FloatingLines from "../components/FloatingLines.jsx";
import SiteHeader from "../components/SiteHeader.astro";
import LightRays from "../components/LightRays.jsx";
import LiquidEther from "../components/LiquidEther.jsx";
import ScrollStack, { ScrollStackItem } from "../components/ScrollStack.jsx";
import ProcessCardStack from "../components/ProcessCardStack.jsx";
import { portfolioDemos } from "../features/portfolio/data/portfolioDemos";
import { HeroParallax } from "../components/HeroParallax";
import { bmSiteUrl, ctaHref, header, hero, metadata, navigation, siteUrl } from "../data/site/home.en";

const pageTitle = metadata.title;
const pageDescription = metadata.description;
const socialPreview = metadata.socialPreview;

const services = [
  {
    title: "Landing pages",
    description: "A focused page for one offer, built to explain value fast and guide visitors toward an inquiry.",
    points: ["Offer clarity", "CTA flow", "Mobile speed"],
    icon: Sparkles,
  },
  {
    title: "Business websites",
    description: "A polished site that presents your services clearly, builds confidence, and makes contacting you easy.",
    points: ["Service structure", "Trust signals", "Contact paths"],
    icon: PanelsTopLeft,
  },
  {
    title: "Systems and automation",
    description: "Workflows, integrations, and automated processes that reduce manual work and keep your business running without constant hands-on input.",
    points: ["Workflow automation", "Tool integrations", "Auto-reporting setup"],
    icon: Wrench,
  },
];

const packages = [
  {
    name: "Starter Website",
    price: "From RM800",
    detail: "A lean sales page for one clear offer, built to explain value fast and move visitors toward an inquiry.",
    points: ["Sales-focused one-page build", "Mobile buying path", "SEO and speed basics"],
    freeFeatures: ["WhatsApp CTA setup", "Basic on-page SEO", "Mobile responsive check"],
    tiers: [
      { name: "Basic", price: "RM800", scope: "One landing page, WhatsApp CTA, basic SEO", meta: "1 revision / 3-5 working days" },
      { name: "Plus", price: "RM1,200", scope: "Stronger copy flow, basic motion, extra polish", meta: "2 revisions / 5-7 working days" },
      { name: "Pro", price: "RM1,600", scope: "Premium landing page with deeper sections", meta: "3 revisions / 7-10 working days" },
    ],
    note: "Client provides logo, content, images, domain, and hosting access.",
  },
  {
    name: "Business Website",
    price: "From RM1,800",
    detail: "A conversion-minded website for service businesses that need credibility, proof, and steady inquiry paths.",
    points: ["Service sections that sell", "Trust-building copy", "Inquiry-ready handoff"],
    freeFeatures: ["Contact path setup", "Basic analytics setup", "Launch checklist"],
    tiers: [
      { name: "Basic", price: "RM1,800", scope: "Three-page business website with clear contact paths", meta: "1 revision / 7-10 working days" },
      { name: "Plus", price: "RM2,500", scope: "Five-page site with stronger service structure", meta: "2 revisions / 10-14 working days", recommended: true },
      { name: "Pro", price: "RM3,500", scope: "Five to seven pages with proof and portfolio sections", meta: "3 revisions / 14-18 working days" },
    ],
    note: "Client provides brand assets, service content, and images. Copywriting support available on request.",
  },
  {
    name: "Custom Build",
    price: "From RM4,000",
    detail: "A tailored sales flow for offers that need richer content, integrations, or room to scale.",
    points: ["Custom buyer journey", "Integration planning", "Post-launch sales notes"],
    freeFeatures: ["Discovery call", "Integration plan", "Post-launch handoff notes"],
    tiers: [
      { name: "Basic", price: "RM4,000", scope: "Custom layout or special sales flow", meta: "2 revisions / 2-3 weeks" },
      { name: "Plus", price: "RM5,500", scope: "Custom website with booking or integration planning", meta: "3 revisions / 3-4 weeks" },
      { name: "Pro", price: "RM7,500+", scope: "Larger custom project with deeper launch support", meta: "Scoped after discovery" },
    ],
    note: "Final scope is confirmed after reviewing pages, features, integrations, and content readiness.",
  },
];

const packageTierOptions = packages.flatMap((item) =>
  item.tiers.map((tier) => ({
    group: item.name,
    value: `${item.name} - ${tier.name} (${tier.price})`,
    label: `${tier.name} - ${tier.price}`,
    summary: tier.scope,
    meta: tier.meta,
    freeFeatures: item.freeFeatures.join(", "),
  })),
);

const websiteTypes = [
  {
    name: "Landing Page",
    detail: "Best when one offer needs a sharper pitch, fast trust, and a direct path to inquiry.",
  },
  {
    name: "Business Website",
    detail: "Best when buyers need to understand your services before they reach out.",
  },
  {
    name: "Custom Website",
    detail: "Best for custom sales flows, richer content, integrations, or a bigger launch plan.",
  },
];

const pageOptions = ["Home", "Services", "Portfolio", "About", "Contact", "Pricing", "Blog", "Privacy"];

const featureOptions = ["Contact form", "Booking link", "Map/location", "Gallery", "Testimonials", "Analytics", "SEO setup", "Basic animations"];

const businessTypes = ["Restaurant / cafe", "Beauty / personal care", "Automotive", "Retail / shop", "Professional service", "Freelancer / creator", "Other local business", "Online business"];

const contentReadinessOptions = ["Logo, text, and images are ready", "I have logo only", "Need help with text", "Need help with images/content"];

const domainOwnershipOptions = ["Yes, I already own a domain", "No, I need domain help"];

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#181512" />
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={siteUrl} />
    <link rel="alternate" hreflang="en" href={siteUrl} />
    <link rel="alternate" hreflang="ms-MY" href={bmSiteUrl} />
    <link rel="alternate" hreflang="x-default" href={siteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={socialPreview} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Mavora Labs — Websites that help businesses generate sales" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialPreview} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=IM+Fell+French+Canon:ital@0;1&family=Cormorant+Infant:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="icon" href="/logo-transparent.png" />
    <title>{pageTitle}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Mavora Labs",
      "url": "https://mavoralabs.com",
      "logo": "https://mavoralabs.com/logo.png",
      "description": "Mavora Labs builds polished, fast-loading websites that help businesses earn trust, capture qualified inquiries, and generate more sales.",
      "areaServed": {
        "@type": "Country",
        "name": "Malaysia"
      },
      "serviceType": ["Web Design", "Web Development", "Landing Page Design", "Business Website Design"],
      "priceRange": "RM800–RM5500+",
      "availableLanguage": ["English", "Malay"],
      "sameAs": []
    }
    </script>
  </head>
  <body class="text-ink antialiased">
    <a href="#services" class="skip-nav">Skip to content</a>
    <SiteHeader
      navigation={navigation}
      ctaHref={ctaHref}
      currentLocale="en"
      navAriaLabel={header.navAriaLabel}
      homeAriaLabel={header.homeAriaLabel}
      menuOpenLabel={header.menuOpenLabel}
      menuCloseLabel={header.menuCloseLabel}
      ctaLabel={header.ctaLabel}
      ctaLabelShort={header.ctaLabelShort}
    />

    <main id="top">
      <HeroParallax
        client:load
        heading={hero.title}
        subheading={hero.copy}
        kicker={hero.kicker}
        ctaHref={ctaHref}
        ctaLabel={hero.primaryCta}
        ctaSecondaryHref="#services"
        ctaSecondaryLabel={hero.secondaryCta}
        proofLine={hero.proofLine}
        products={[
          { title: "Web design in progress", link: "#packages", thumbnail: "https://images.unsplash.com/photo-1467232004584-a241de8bcf5d?w=600&q=80" },
          { title: "Business website", link: "#packages", thumbnail: "https://images.unsplash.com/photo-1497366216548-37526070297c?w=600&q=80" },
          { title: "Service page", link: "#services", thumbnail: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&q=80" },
          { title: "Portfolio site", link: "#portfolio", thumbnail: "https://images.unsplash.com/photo-1507238691740-187a5b1d37b8?w=600&q=80" },
          { title: "Ecommerce page", link: "#packages", thumbnail: "https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=600&q=80" },
          { title: "Restaurant website", link: "#portfolio", thumbnail: "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=600&q=80" },
          { title: "Beauty studio site", link: "#portfolio", thumbnail: "https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=600&q=80" },
          { title: "Freelancer portfolio", link: "#portfolio", thumbnail: "https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=600&q=80" },
          { title: "Agency website", link: "#services", thumbnail: "https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=600&q=80" },
          { title: "Consulting site", link: "#services", thumbnail: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=600&q=80" },
          { title: "Product launch page", link: "#packages", thumbnail: "https://images.unsplash.com/photo-1531297484001-80022131f5a1?w=600&q=80" },
          { title: "Automotive business", link: "#portfolio", thumbnail: "https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?w=600&q=80" },
          { title: "Retail shop page", link: "#packages", thumbnail: "https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=600&q=80" },
          { title: "Professional service", link: "#services", thumbnail: "https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=600&q=80" },
          { title: "Local business site", link: "#packages", thumbnail: "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=600&q=80" },
        ]}
      />

      <section class="studio-statement story-section bg-ink px-5 py-20 text-white sm:px-6 lg:px-8">
        <div class="liquid-section-bg liquid-section-bg--statement" aria-hidden="true">
          <LiquidEther
            client:visible
            colors={["#9ff58f", "#176b4d", "#063b2c"]}
            mouseForce={18}
            cursorSize={116}
            resolution={0.5}
            autoSpeed={0.46}
            autoIntensity={2.05}
            autoResumeDelay={1600}
            autoRampDuration={0.8}
          />
        </div>
        <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.88fr_1.12fr] lg:items-start">
          <div class="studio-motion studio-motion--headline">
            <p class="topic-label text-white/68">Mavora Labs</p>
            <h2 class="story-heading mt-4 text-4xl font-semibold tracking-normal sm:text-5xl">Small studio focus. Websites built to sell.</h2>
          </div>
          <div class="studio-statement__copy studio-motion studio-motion--copy">
            <p class="studio-statement__intro text-lg leading-8 text-white/74">
              Mavora Labs builds for founders and local service businesses that need a site visitors understand, trust, and act on — without the overhead of a large agency.
            </p>
            <ul class="studio-principles" aria-label="Mavora Labs website principles">
              <li>
                <span class="studio-principles__index">01</span>
                <div>
                  <h3>Offer clarity</h3>
                  <p>Your page explains what you offer, who it's for, and why it matters — before attention runs out.</p>
                </div>
              </li>
              <li>
                <span class="studio-principles__index">02</span>
                <div>
                  <h3>Buyer confidence</h3>
                  <p>Copy, proof, and structure guide visitors from first glance to ready to contact.</p>
                </div>
              </li>
              <li>
                <span class="studio-principles__index">03</span>
                <div>
                  <h3>Launch focus</h3>
                  <p>Lean, fast builds with clean handoff — and a direct path from the site to WhatsApp.</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <section id="services" class="story-section bg-paper px-5 py-20 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
          <div class="text-center">
            <p class="topic-label text-ember">Our services</p>
            <h2 class="story-heading mt-4 text-4xl font-semibold tracking-normal text-ink sm:text-5xl">We solve business pipelines problem.</h2>
          </div>
          <div class="svc3d-stage">
            <div class="svc3d-scene" id="svc3d-scene">
              {services.map((service, i) => {
                const Icon = service.icon;
                return (
                  <article class="svc3d-card service-card" data-index={i}>
                    <div class="service-card__top">
                      <span class="service-card__icon inline-flex h-11 w-11 items-center justify-center rounded-full">
                        <Icon class="h-5 w-5" aria-hidden="true" />
                      </span>
                      <h3 class="service-card__title text-xl font-semibold">{service.title}</h3>
                    </div>
                    <p class="service-card__desc mt-6 leading-7">{service.description}</p>
                    <ul class="service-card__points mt-6">
                      {service.points.map((point) => <li>{point}</li>)}
                    </ul>
                  </article>
                );
              })}
              <button class="pkg3d-btn" id="svc3d-prev" aria-label="Previous service" type="button">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
              </button>
              <button class="pkg3d-btn" id="svc3d-next" aria-label="Next service" type="button">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </button>
            </div>
            <div class="pkg3d-controls">
              <div class="pkg3d-dots" role="tablist" aria-label="Service selector">
                {services.map((svc, i) => (
                  <button class={`pkg3d-dot svc3d-dot${i === 0 ? " is-active" : ""}`} type="button" role="tab" aria-label={svc.title}></button>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="portfolio" class="portfolio-section story-section" aria-label="Portfolio demos">
        <div class="light-rays-section-bg light-rays-section-bg--portfolio" aria-hidden="true">
          <LightRays
            client:visible
            raysOrigin="top-center"
            raysColor="#9ff58f"
            raysSpeed={3.2}
            lightSpread={2.35}
            rayLength={2.6}
            followMouse={true}
            mouseInfluence={0.48}
            noiseAmount={0.18}
            distortion={0.16}
            fadeDistance={2.7}
            saturation={1.0}
            pulsating={true}
          />
        </div>
        <ul class="pf-slider" id="pf-slider">
          {portfolioDemos.map((demo) => (
            <li class="pf-item" style={`background-image: url('${demo.image}')`} data-slug={demo.slug}>
              <div class="pf-content">
                <p class="pf-eyebrow">{demo.businessType}</p>
                <h2 class="pf-title">{demo.name}</h2>
                <p class="pf-desc">{demo.headline}</p>
                <a href={`/portfolio/${demo.slug}/`} class="pf-cta">View demo</a>
              </div>
            </li>
          ))}
        </ul>
        <nav class="pf-nav">
          <button class="pf-btn pf-prev" id="pf-prev" aria-label="Previous demo" type="button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <button class="pf-btn pf-next" id="pf-next" aria-label="Next demo" type="button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        </nav>
        <div class="pf-view-all">
          <a href="/portfolio/" class="ui-button inline-flex items-center gap-2 rounded-full bg-white px-5 py-3 text-sm font-semibold text-ink transition hover:bg-mist">
            View all demos
            <ArrowRight class="h-4 w-4" aria-hidden="true" />
          </a>
        </div>
      </section>

      <section id="packages" class="story-section bg-paper px-5 py-12 sm:px-6 lg:px-8" style="--section-bg: #fbf7ef">
        <div class="mx-auto max-w-6xl">
          <div class="text-center">
            <p class="topic-label text-ember">Our packages</p>
            <h2 class="story-heading mt-4 text-4xl font-semibold tracking-normal text-ink sm:text-5xl">Build your dream website with us</h2>
          </div>
          <div class="pkg3d-stage">
            <div class="pkg3d-scene" id="pkg3d-scene">
              {packages.map((item, index) => (
                <article class="pkg3d-card package-card" data-index={index}>
                  <div class="card-summary">
                    <span class="card-index">0{index + 1}</span>
                    <h3 class="text-2xl font-semibold">{item.name}</h3>
                    <p class="package-price"><span class="price-label">{item.price.split(' ')[0]}</span><span class="price-amount">{item.price.split(' ').slice(1).join(' ')}</span></p>
                  </div>
                  <ul class="card-pill-list">
                    {item.points.map((point) => (
                      <li>
                        <CircleCheck class="h-4 w-4 shrink-0 text-moss" aria-hidden="true" />
                        <span>{point}</span>
                      </li>
                    ))}
                  </ul>
                  <div class="package-freebies">
                    <p>Free included</p>
                    <ul>
                      {item.freeFeatures.map((feature) => (
                        <li>
                          <CircleCheck class="h-4 w-4 shrink-0 text-moss" aria-hidden="true" />
                          <span>{feature}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div class="package-tier-carousel" aria-label={`${item.name} package tiers`}>
                    <div class="package-tier-track">
                      {item.tiers.map((tier) => (
                        <div class={`package-tier ${tier.recommended ? "package-tier--featured" : ""}`}>
                          <div class="package-tier__top">
                            <span class="package-tier__name">{tier.name}</span>
                            {tier.recommended && <span class="package-tier__badge">Recommended</span>}
                          </div>
                          <strong>{tier.price}</strong>
                          <p>{tier.scope}</p>
                          <small>{tier.meta}</small>
                        </div>
                      ))}
                    </div>
                    <div class="package-tier-dots" aria-hidden="true">
                      {item.tiers.map((tier, ti) => (
                        <button class={`package-tier-dot${ti === 0 ? " is-active" : ""}`} type="button" tabindex="-1"></button>
                      ))}
                    </div>
                  </div>
                  <p class="package-note">{item.note}</p>
                  <a href="#project-request" data-package={item.name} class="ui-button package-card__cta mt-5 inline-flex w-full items-center justify-center gap-2 rounded-full bg-ember px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#6f2119]">
                    Request this package
                    <ArrowRight class="h-4 w-4" aria-hidden="true" />
                  </a>
                </article>
              ))}
              <button class="pkg3d-btn" id="pkg3d-prev" aria-label="Previous package" type="button">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
              </button>
              <button class="pkg3d-btn" id="pkg3d-next" aria-label="Next package" type="button">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </button>
            </div>
            <div class="pkg3d-controls">
              <div class="pkg3d-dots" role="tablist" aria-label="Package selector">
                {packages.map((item, i) => (
                  <button class={`pkg3d-dot${i === 0 ? " is-active" : ""}`} type="button" role="tab" aria-label={item.name}></button>
                ))}
              </div>
            </div>
          </div>
          <p class="package-footnote">Final pricing depends on page count, content readiness, features, integrations, copywriting needs, and launch support. Payment is 50% deposit to start and 50% before launch.</p>
        </div>
      </section>

      <section id="process" class="process-section story-section relative overflow-hidden bg-mist px-5 py-20 sm:px-6 lg:px-8">
        <div class="light-rays-section-bg light-rays-section-bg--process" aria-hidden="true">
          <LightRays
            client:visible
            raysOrigin="left"
            raysColor="#176b4d"
            raysSpeed={2.3}
            lightSpread={1.55}
            rayLength={2.0}
            followMouse={true}
            mouseInfluence={0.34}
            noiseAmount={0.12}
            distortion={0.1}
            fadeDistance={2.2}
            saturation={1.0}
            pulsating={true}
          />
        </div>
        <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.86fr_1.14fr] lg:items-start">
          <div>
            <p class="topic-label text-moss">Our process</p>
            <h2 class="story-heading mt-4 text-4xl font-semibold tracking-normal text-ink sm:text-5xl">From rough idea to a website ready to sell.</h2>
            <p class="mt-5 leading-8 text-ink/68">
              A focused process that turns your offer into clear copy, polished design, fast pages, and a confident launch path.
            </p>
          </div>
          <ProcessCardStack client:visible />
        </div>
      </section>

      <section id="faq" class="faq-section story-section px-5 py-20 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
          <div class="grid gap-10 lg:grid-cols-[0.72fr_1.28fr] lg:items-start">
            <div class="lg:sticky lg:top-28">
              <p class="topic-label text-ember">Common questions</p>
              <h2 class="story-heading mt-4 text-4xl font-semibold tracking-normal text-ink sm:text-5xl">Things people usually ask before reaching out.</h2>
              <p class="mt-5 leading-8 text-ink/66">If your question isn't here, send it directly via WhatsApp when you submit the request form.</p>
            </div>
            <ul class="faq-list mt-2 bg-white">
              <li class="faq-item">
                <details>
                  <summary>Do I need to have all my content ready before reaching out?</summary>
                  <p class="faq-answer">No. You only need a rough idea of what your business does and who it serves. Content readiness is one of the questions in the request form, and the scope can be adjusted to include copywriting support if needed.</p>
                </details>
              </li>
              <li class="faq-item">
                <details>
                  <summary>What happens after I send the WhatsApp request?</summary>
                  <p class="faq-answer">You'll get a reply confirming the scope summary, proposed package, timeline, and next steps. From there, we agree on the scope, and you pay the 50% deposit to start. The remaining 50% is paid before launch.</p>
                </details>
              </li>
              <li class="faq-item">
                <details>
                  <summary>Do I need to handle my own hosting and domain?</summary>
                  <p class="faq-answer">Yes. You'll need to own your domain and have a hosting account. If you don't have these yet, the process is straightforward and guidance is included. This keeps you in control of your own website after launch.</p>
                </details>
              </li>
              <li class="faq-item">
                <details>
                  <summary>How long does a typical project take?</summary>
                  <p class="faq-answer">Starter pages typically take 3–10 working days depending on the tier. Business websites run 7–18 working days. Custom builds are scoped individually. Timeline starts once the deposit is paid and content is provided.</p>
                </details>
              </li>
              <li class="faq-item">
                <details>
                  <summary>Can I request edits after the site is launched?</summary>
                  <p class="faq-answer">Revisions are included in every package (1–3 depending on tier), all used during the build. Post-launch edits are handled as separate support requests and quoted based on scope.</p>
                </details>
              </li>
              <li class="faq-item">
                <details>
                  <summary>Is the starting price the final price?</summary>
                  <p class="faq-answer">Starting prices reflect the base tier. Final pricing depends on page count, content readiness, extra features, integrations, copywriting, and launch support needs. The full breakdown is confirmed before any payment is made.</p>
                </details>
              </li>
            </ul>
          </div>
        </div>
      </section>

