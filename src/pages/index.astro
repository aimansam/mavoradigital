                    <label class="block">
                      <span class="text-sm font-semibold text-ink">Main website goal</span>
                      <input name="mainGoal" type="text" autocomplete="off" maxlength="200" class="mt-2 h-12 w-full rounded-lg border border-line bg-white px-4 text-ink outline-none transition focus:border-ember" placeholder="More bookings or inquiries" />
                    </label>
                  </div>
                </div>
              </div>

              <!-- Step 4: Notes + Submit -->
              <div class="form-step-panel" data-step="3">
                <p class="form-step-heading">Anything important to add?</p>
                <div class="space-y-6">
                  <label class="block">
                    <span class="text-sm font-semibold text-ink">Project notes</span>
                    <textarea name="projectNotes" rows="5" autocomplete="off" maxlength="1200" class="mt-2 w-full rounded-lg border border-line bg-white px-4 py-3 text-ink outline-none transition focus:border-ember" placeholder="Must-have details, examples, or concerns."></textarea>
                  </label>
                  <div class="submit-panel flex flex-col gap-4 rounded-lg border border-line bg-paper p-5 md:flex-row md:items-center md:justify-between">
                    <div class="space-y-2">
                      <p id="project-request-status" class="leading-7 text-ink/68">Your request opens in WhatsApp before sending. No payment is required from this form.</p>
                      <p class="text-sm leading-6 text-ink/58">Contact details can be confirmed after the quote.</p>
                      <p class="text-sm leading-6"><a href="/privacy/" class="font-semibold text-ember transition hover:text-ink">View privacy note</a></p>
                    </div>
                    <button id="project-request-submit" type="submit" class="ui-button submit-button inline-flex min-h-12 min-w-44 items-center justify-center gap-2 whitespace-nowrap rounded-full bg-ember px-6 text-base font-semibold text-white transition hover:bg-[#6f2119]">
                      <MessageCircle class="submit-icon h-5 w-5" aria-hidden="true" />
                      <span class="submit-label">Send to WhatsApp</span>
