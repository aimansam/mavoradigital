---
import "../../styles/global.css";
import { ArrowLeft, ArrowRight, CircleCheck } from "@lucide/astro";
import { portfolioDemos } from "../../features/portfolio/data/portfolioDemos";

const packageFilters = ["All", "Landing Page", "Business Website", "Custom Build"];

const landingPageDemos = portfolioDemos.filter((d) => d.packageFit === "Landing Page");
const businessDemos = portfolioDemos.filter((d) => d.packageFit === "Business Website");
const customDemos = portfolioDemos.filter((d) => d.packageFit === "Custom Build");

const packageMeta: Record<string, { label: string; description: string }> = {
  "Landing Page": {
    label: "Landing Page",
    description: "One focused page for one clear offer. Built to explain value fast and move visitors toward an inquiry.",
  },
  "Business Website": {
    label: "Business Website",
    description: "A conversion-minded site for service businesses that need credibility, proof, and steady inquiry paths.",
  },
  "Custom Build": {
    label: "Custom Build",
    description: "A tailored sales flow for offers that need richer content, integrations, or room to scale.",
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Real website demos built by Mavora Digital — explore every niche and package tier, then request yours." />
    <link rel="canonical" href="https://mavoradigital.com/portfolio/" />
    <meta name="theme-color" content="#fbf7ef" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://mavoradigital.com/portfolio/" />
    <meta property="og:title" content="Portfolio | Mavora Digital" />
    <meta property="og:description" content="Real website demos built by Mavora Digital — explore every niche and package tier, then request yours." />
    <meta property="og:image" content="https://mavoradigital.com/social-preview.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Mavora Digital Portfolio — Website demos for local businesses" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Portfolio | Mavora Digital" />
    <meta name="twitter:description" content="Real website demos built by Mavora Digital — explore every niche and package tier, then request yours." />
    <meta name="twitter:image" content="https://mavoradigital.com/social-preview.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700&family=Poppins:wght@500;600;700&display=swap" rel="stylesheet" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="icon" href="/logo-transparent.png" />
    <title>Portfolio | Mavora Digital</title>
  </head>
  <body class="antialiased" style="background:#0d1f1a;">
    <header class="border-b border-line bg-white px-5 py-5 sm:px-6 lg:px-8">
      <nav class="mx-auto flex max-w-6xl items-center justify-between gap-4" aria-label="Portfolio navigation">
        <a href="/" class="flex h-11 w-48 items-center rounded-full bg-white px-4 shadow-[0_8px_20px_rgba(17,24,39,0.06)]" aria-label="Mavora Digital home">
          <img src="/logo-transparent.png" alt="Mavora Digital" class="h-auto w-full object-contain" width="980" height="313" />
        </a>
        <a href="/" class="inline-flex items-center gap-2 rounded-full border border-line px-4 py-2 text-sm font-semibold transition hover:border-ember hover:text-ember">
          <ArrowLeft class="h-4 w-4" aria-hidden="true" />
          Home
        </a>
      </nav>
    </header>

    <main>
      <section class="px-5 py-16 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
          <p class="topic-label text-ember">OUR PORTFOLIO</p>
          <h1 class="mt-4 max-w-3xl text-5xl font-semibold leading-tight tracking-normal text-white sm:text-6xl">Built to impress. Designed to convert.</h1>
          <p class="mt-5 max-w-2xl text-lg leading-8" style="color:rgba(255,255,255,0.62);">
            Real demos across every niche and package tier. Explore the design, copy, and structure — then request yours.
          </p>
        </div>
      </section>

      <section class="px-5 pb-6 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
          <div class="portfolio-filter-bar" aria-label="Filter portfolio demos by package">
            {packageFilters.map((filter) => (
              <button class="portfolio-filter-button" type="button" data-filter={filter} aria-pressed={filter === "All" ? "true" : "false"}>
                {filter}
              </button>
            ))}
          </div>
        </div>
      </section>

      {/* Landing Page Group */}
      {landingPageDemos.length > 0 && (
        <section class="portfolio-group px-5 pb-12 sm:px-6 lg:px-8" data-package-group="Landing Page">
          <div class="mx-auto max-w-6xl">
            <div class="mb-8 border-b border-line/40 pb-6">
              <p class="topic-label text-ember">{packageMeta["Landing Page"].label}</p>
              <p class="mt-2 max-w-2xl leading-7" style="color:rgba(255,255,255,0.62);">{packageMeta["Landing Page"].description}</p>
            </div>
            <div class="portfolio-index-grid">
              {landingPageDemos
                .filter((d) => !d.slug.startsWith("kopi-jiran-") || d.slug === "kopi-jiran")
                .map((demo) => {
                  const variants = (demo as any).variants;
                  return (
                    <article
                      class={`portfolio-index-card overflow-hidden rounded-lg border border-line bg-white shadow-[0_10px_28px_rgba(17,24,39,0.06)]${variants ? " portfolio-card--with-variants" : ""}`}
                      data-package={demo.packageFit}
                      data-slug={demo.slug}
                    >
                      <div class="portfolio-card__media relative">
                        <img
                          src={demo.image}
                          alt={`${demo.businessType} landing page concept`}
                          class="portfolio-card__img h-56 w-full object-cover"
                          width="900"
                          height="600"
                          loading="lazy"
                        />
                        {variants && (
                          <div class="portfolio-card__variant-bar absolute bottom-0 left-0 right-0 flex items-center justify-center gap-2 bg-gradient-to-t from-black/80 via-black/50 to-transparent p-4 pt-10">
                            {variants.map((v, i) => (
                              <button
                                type="button"
                                class={`portfolio-variant-btn inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-[11px] font-bold text-white shadow-lg transition hover:scale-105${i === 0 ? " is-active" : " border-white/40 bg-black/70 hover:bg-black/90"}`}
                                data-variant-slug={v.slug}
                                data-variant-primary={v.primary}
                                data-variant-dark={v.dark}
                                aria-label={`View ${v.label} theme`}
                                style={i === 0 ? `background:${v.primary}44;border-color:${v.primary}` : ""}
                              >
                                <span class="portfolio-variant-swatch inline-block h-2 w-2 rounded-full ring-1 ring-white/60" style={`background:${v.primary}`} />
                                <span>{v.label}</span>
                              </button>
                            ))}
                          </div>
                        )}
                      </div>
                      <div class="p-6">
                        <p class="topic-label topic-label--small text-ember">{demo.businessType}</p>
                        <h2 class="mt-3 text-2xl font-semibold text-ink">{demo.name}</h2>
                        <div class="portfolio-card__package portfolio-card__package--light mt-4" data-package={demo.packageFit}>
                          <span>{demo.packageFit} - {demo.tier}</span>
                          <strong>{demo.packagePrice}</strong>
                        </div>
                        <p class="mt-3 leading-7 text-ink/66">{demo.summary}</p>
                        <ul class="portfolio-index-value-list mt-5" aria-label={`${demo.name} package value proof`}>
                          {demo.valueProof.slice(0, 3).map((proof) => (
                            <li>
                              <CircleCheck class="h-4 w-4 shrink-0 text-moss" aria-hidden="true" />
                              <span>{proof}</span>
                            </li>
                          ))}
                        </ul>
                        <a
                          href={"externalHref" in demo ? (demo as { externalHref: string }).externalHref : `/portfolio/${demo.slug}/`}
                          target={"externalHref" in demo ? "_blank" : undefined}
                          rel={"externalHref" in demo ? "noreferrer noopener" : undefined}
                          class="portfolio-card__cta mt-6 inline-flex items-center gap-2 rounded-full bg-ink px-4 py-2 text-sm font-semibold text-white transition hover:bg-moss"
                        >
                          <span aria-hidden="true">{"externalHref" in demo ? "Visit live app" : "View demo"}</span>
                          <span class="sr-only">{"externalHref" in demo ? `Visit ${demo.name}` : `View ${demo.name} demo`}</span>
                          <ArrowRight class="h-4 w-4" aria-hidden="true" />
                        </a>
                      </div>
                    </article>
                  );
                })}
            </div>
          </div>
        </section>
      )}

      {/* Business Website Group */}
      {businessDemos.length > 0 && (
        <section class="portfolio-group px-5 pb-12 sm:px-6 lg:px-8" data-package-group="Business Website">
          <div class="mx-auto max-w-6xl">
            <div class="mb-8 border-b border-line/40 pb-6">
              <p class="topic-label text-ember">{packageMeta["Business Website"].label}</p>
              <p class="mt-2 max-w-2xl leading-7" style="color:rgba(255,255,255,0.62);">{packageMeta["Business Website"].description}</p>
            </div>
            <div class="portfolio-index-grid">
              {businessDemos.map((demo) => (
                <article class="portfolio-index-card overflow-hidden rounded-lg border border-line bg-white shadow-[0_10px_28px_rgba(17,24,39,0.06)]" data-package={demo.packageFit}>
                  <img src={demo.image} alt={`${demo.businessType} landing page concept`} class="h-56 w-full object-cover" width="900" height="600" loading="lazy" />
                  <div class="p-6">
                    <p class="topic-label topic-label--small text-ember">{demo.businessType}</p>
                    <h2 class="mt-3 text-2xl font-semibold text-ink">{demo.name}</h2>
                    <div class="portfolio-card__package portfolio-card__package--light mt-4" data-package={demo.packageFit}>
                      <span>{demo.packageFit} - {demo.tier}</span>
                      <strong>{demo.packagePrice}</strong>
                    </div>
                    <p class="mt-3 leading-7 text-ink/66">{demo.summary}</p>
                    <ul class="portfolio-index-value-list mt-5" aria-label={`${demo.name} package value proof`}>
                      {demo.valueProof.slice(0, 3).map((proof) => (
                        <li>
                          <CircleCheck class="h-4 w-4 shrink-0 text-moss" aria-hidden="true" />
                          <span>{proof}</span>
                        </li>
                      ))}
                    </ul>
                    <a
                      href={"externalHref" in demo ? (demo as { externalHref: string }).externalHref : `/portfolio/${demo.slug}/`}
                      target={"externalHref" in demo ? "_blank" : undefined}
                      rel={"externalHref" in demo ? "noreferrer noopener" : undefined}
                      class="mt-6 inline-flex items-center gap-2 rounded-full bg-ink px-4 py-2 text-sm font-semibold text-white transition hover:bg-moss"
                    >
                      <span aria-hidden="true">{"externalHref" in demo ? "Visit live app" : "View demo"}</span>
                      <span class="sr-only">{"externalHref" in demo ? `Visit ${demo.name}` : `View ${demo.name} demo`}</span>
                      <ArrowRight class="h-4 w-4" aria-hidden="true" />
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>
      )}

      {/* Custom Build Group */}
      {customDemos.length > 0 && (
        <section class="portfolio-group px-5 pb-12 sm:px-6 lg:px-8" data-package-group="Custom Build">
          <div class="mx-auto max-w-6xl">
            <div class="mb-8 border-b border-line/40 pb-6">
              <p class="topic-label text-ember">{packageMeta["Custom Build"].label}</p>
              <p class="mt-2 max-w-2xl leading-7" style="color:rgba(255,255,255,0.62);">{packageMeta["Custom Build"].description}</p>
            </div>
            <div class="portfolio-index-grid">
              {customDemos.map((demo) => (
                <article class="portfolio-index-card overflow-hidden rounded-lg border border-line bg-white shadow-[0_10px_28px_rgba(17,24,39,0.06)]" data-package={demo.packageFit}>
                  <img src={demo.image} alt={`${demo.businessType} landing page concept`} class="h-56 w-full object-cover" width="900" height="600" loading="lazy" />
                  <div class="p-6">
                    <p class="topic-label topic-label--small text-ember">{demo.businessType}</p>
                    <h2 class="mt-3 text-2xl font-semibold text-ink">{demo.name}</h2>
                    <div class="portfolio-card__package portfolio-card__package--light mt-4" data-package={demo.packageFit}>
                      <span>{demo.packageFit} - {demo.tier}</span>
                      <strong>{demo.packagePrice}</strong>
                    </div>
                    <p class="mt-3 leading-7 text-ink/66">{demo.summary}</p>
                    <ul class="portfolio-index-value-list mt-5" aria-label={`${demo.name} package value proof`}>
                      {demo.valueProof.slice(0, 3).map((proof) => (
                        <li>
                          <CircleCheck class="h-4 w-4 shrink-0 text-moss" aria-hidden="true" />
                          <span>{proof}</span>
                        </li>
                      ))}
                    </ul>
                    <a
                      href={"externalHref" in demo ? (demo as { externalHref: string }).externalHref : `/portfolio/${demo.slug}/`}
                      target={"externalHref" in demo ? "_blank" : undefined}
                      rel={"externalHref" in demo ? "noreferrer noopener" : undefined}
                      class="mt-6 inline-flex items-center gap-2 rounded-full bg-ink px-4 py-2 text-sm font-semibold text-white transition hover:bg-moss"
                    >
                      <span aria-hidden="true">{"externalHref" in demo ? "Visit live app" : "View demo"}</span>
                      <span class="sr-only">{"externalHref" in demo ? `Visit ${demo.name}` : `View ${demo.name} demo`}</span>
                      <ArrowRight class="h-4 w-4" aria-hidden="true" />
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>
      )}

      <section class="px-5 pb-20 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
          <div class="portfolio-empty-state mt-8 hidden rounded-lg border border-line bg-white p-8 text-center" aria-live="polite">
            <p class="topic-label topic-label--small text-ember">More examples coming soon</p>
            <h2 class="mt-3 text-2xl font-semibold text-ink">No demos match this package yet.</h2>
            <p class="mx-auto mt-3 max-w-xl leading-7 text-ink/66">Send a custom scope request and we can shape a package around your business flow.</p>
            <a href="/#project-request" class="mt-6 inline-flex items-center gap-2 rounded-full bg-ink px-5 py-3 text-sm font-semibold text-white transition hover:bg-moss">
              Request a custom scope
              <ArrowRight class="h-4 w-4" aria-hidden="true" />
            </a>
          </div>
        </div>
      </section>
    </main>

    <script>
      const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>(".portfolio-filter-button"));
      const portfolioCards = Array.from(document.querySelectorAll<HTMLElement>(".portfolio-index-card"));
      const portfolioGroups = Array.from(document.querySelectorAll<HTMLElement>("[data-package-group]"));
      const emptyState = document.querySelector<HTMLElement>(".portfolio-empty-state");

      const applyPortfolioFilter = (filter: string) => {
        let visibleCount = 0;

        portfolioCards.forEach((card) => {
          const isVisible = filter === "All" || card.dataset.package === filter;
          card.hidden = !isVisible;
          if (isVisible) visibleCount += 1;
        });

        // Hide/show entire group sections based on whether any card in them is visible
        portfolioGroups.forEach((group) => {
          const groupLabel = group.dataset.packageGroup || "";
          const groupVisible = filter === "All" || groupLabel === filter;
          group.hidden = !groupVisible;
        });

        filterButtons.forEach((button) => {
          button.setAttribute("aria-pressed", String(button.dataset.filter === filter));
        });

        emptyState?.classList.toggle("hidden", visibleCount > 0);
      };

      filterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          applyPortfolioFilter(button.dataset.filter || "All");
        });
      });

      // Variant theme switcher on portfolio cards
      document.querySelectorAll<HTMLElement>(".portfolio-card--with-variants").forEach((card) => {
        const img = card.querySelector<HTMLImageElement>(".portfolio-card__img");
        const cta = card.querySelector<HTMLAnchorElement>(".portfolio-card__cta");
        const variantButtons = Array.from(card.querySelectorAll<HTMLButtonElement>(".portfolio-variant-btn"));
        if (!variantButtons.length) return;

        const updateVariant = (activeBtn: HTMLButtonElement) => {
          variantButtons.forEach((btn) => {
            const isActive = btn === activeBtn;
            btn.classList.toggle("is-active", isActive);
            const p = btn.dataset.variantPrimary;
            if (isActive && p) {
              btn.style.background = `${p}33`;
              btn.style.borderColor = `${p}88`;
            } else {
              btn.style.background = "";
              btn.style.borderColor = "";
            }
          });
          const slug = activeBtn.dataset.variantSlug;
          const primary = activeBtn.dataset.variantPrimary;
          const dark = activeBtn.dataset.variantDark;
          if (slug && cta) {
            cta.href = `/portfolio/${slug}/`;
            cta.querySelector("span.sr-only")!.textContent = `View Kopi Jiran ${activeBtn.textContent?.trim() || ""} demo`;
          }
          if (primary) card.style.borderColor = `${primary}33`;
          if (dark) card.style.setProperty("--demo-accent", dark);
        };

        variantButtons.forEach((btn) => {
          btn.addEventListener("click", () => updateVariant(btn));
        });
      });
    </script>
  </body>
</html>