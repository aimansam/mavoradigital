---
import "../../styles/global.css";
import { ArrowLeft, ArrowRight, CircleCheck, MapPin, MessageCircle, Star } from "@lucide/astro";
import { portfolioDemos } from "../../features/portfolio/data/portfolioDemos";
import { getPortfolioDemoEntry } from "../../features/portfolio/registry";

export function getStaticPaths() {
  return portfolioDemos
    .filter((demo) => !("externalHref" in demo))
    .map((demo) => ({ params: { slug: demo.slug }, props: { demo } }));
}

const { demo } = Astro.props;
const PortfolioDemoComponent = getPortfolioDemoEntry(demo.slug)?.component;
const packageLabel = `${demo.packageFit} - ${demo.tier}`;
const packageShortName = demo.packageFit.replace(" Website", "");
const packageCtaLabel = `Request ${packageShortName} ${demo.tier}`;
const packageRequestHref = `/?package=${encodeURIComponent(packageLabel)}#project-request`;

const customFlowSteps = [
  {
    title: "Map the buyer journey",
    detail: "Define the steps from discovery to class inquiry so the site supports real booking intent.",
  },
  {
    title: "Compare packages clearly",
    detail: "Show class packs, trials, and membership options in a way visitors can scan quickly.",
  },
  {
    title: "Plan booking or inquiry steps",
    detail: "Shape the booking path, required lead details, and handoff notes before development starts.",
  },
  {
    title: "Prepare launch handoff",
    detail: "Document package content, CTA destinations, analytics notes, and post-launch updates.",
  },
];
const customStudioPackages = [
  { name: "Trial Class", detail: "Best for first-time visitors", price: "RM49" },
  { name: "Class Pack", detail: "Five sessions with flexible booking", price: "RM220" },
  { name: "Monthly Pass", detail: "Recurring plan with priority classes", price: "RM380" },
];
const customLeadFields = ["Preferred class", "Fitness goal", "Best contact time", "WhatsApp number"];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={demo.summary} />
    <link rel="canonical" href={`https://mavoradigital.com/portfolio/${demo.slug}/`} />
    <meta name="theme-color" content="#181512" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://mavoradigital.com/portfolio/${demo.slug}/`} />
    <meta property="og:title" content={`${demo.name} Demo | Mavora Digital`} />
    <meta property="og:description" content={demo.summary} />
    <meta property="og:image" content={demo.image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${demo.name} — Mavora Digital website demo`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${demo.name} Demo | Mavora Digital`} />
    <meta name="twitter:description" content={demo.summary} />
    <meta name="twitter:image" content={demo.image} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700&family=Poppins:wght@500;600;700&display=swap" rel="stylesheet" />
    {demo.slug === "burger-shop" && (
      <>
        <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
        <link href="https://api.fontshare.com/v2/css?f[]=switzer@300&f[]=gambarino@400&display=swap" rel="stylesheet" />
      </>
    )}
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="icon" href="/logo-transparent.png" />
  </head>
  <body class="bg-white text-ink antialiased" style={`--demo-primary: ${demo.primary}; --demo-secondary: ${demo.secondary}; --demo-dark: ${demo.dark}; --demo-light: ${demo.light};`}>
    {!PortfolioDemoComponent && (
      <header class="fixed left-0 right-0 top-0 z-30 border-b border-white/15 bg-[var(--demo-dark)]/90 text-white backdrop-blur">
        <nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-4 sm:px-6 lg:px-8" aria-label="Demo navigation">
          <a href="/portfolio/" class="inline-flex items-center gap-2 text-sm font-semibold text-white/86 transition hover:text-white">
            <ArrowLeft class="h-4 w-4" aria-hidden="true" />
            Demos
          </a>
          <a href="/" class="flex h-10 w-44 items-center rounded-full bg-white px-4" aria-label="Mavora Digital home">
            <img src="/logo-transparent.png" alt="Mavora Digital" class="h-auto w-full object-contain" width="980" height="313" />
          </a>
        </nav>
      </header>
    )}

    {PortfolioDemoComponent ? (
      <PortfolioDemoComponent demo={demo} />
    ) : (
      <main>
        <>
          <section class="relative isolate min-h-[88svh] overflow-hidden text-white">
            <img src={demo.image} alt={`${demo.businessType} landing page hero`} class="absolute inset-0 -z-20 h-full w-full object-cover" width="1800" height="1200" />
            <div class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,rgba(0,0,0,0.82),rgba(0,0,0,0.52),rgba(0,0,0,0.12))]"></div>
            <div class="mx-auto flex min-h-[88svh] max-w-6xl items-end px-5 pb-14 pt-28 sm:px-6 lg:px-8 lg:pb-20">
              <div class="max-w-3xl">
                <p class="topic-label text-white/80">{demo.eyebrow}</p>
                <h1 class="mt-5 text-5xl font-semibold leading-tight tracking-normal sm:text-6xl lg:text-7xl">{demo.headline}</h1>
                <p class="mt-6 max-w-2xl text-lg leading-8 text-white/80">{demo.summary}</p>
                <div class="mt-8 flex flex-col gap-3 sm:flex-row">
                  <a href="#offer" class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full px-6 text-base font-semibold text-white shadow-soft transition hover:brightness-95" style={`background: ${demo.primary};`}>
                    {demo.cta}
                    <ArrowRight class="h-5 w-5" aria-hidden="true" />
                  </a>
                  <a href="/" class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full border border-white/45 px-6 text-base font-semibold text-white transition hover:bg-white hover:text-ink">
                    Built by Mavora Digital
                  </a>
                </div>
              </div>
            </div>
          </section>

          <section class="border-y border-line bg-white px-5 py-8 sm:px-6 lg:px-8">
            <div class="mx-auto grid max-w-6xl gap-4 sm:grid-cols-3">
              {demo.metrics.map((metric) => (
                <div class="flex items-center gap-3 rounded-lg bg-[var(--demo-light)] p-4 font-semibold text-ink">
                  <Star class="h-5 w-5 shrink-0" style={`color: ${demo.primary};`} aria-hidden="true" />
                  <span>{metric}</span>
                </div>
              ))}
            </div>
          </section>

          <section class="demo-package-value px-5 py-16 sm:px-6 lg:px-8">
            <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[0.76fr_1.24fr] lg:items-stretch">
              <div class="demo-package-value__intro rounded-lg p-7 text-white" style={`background: ${demo.dark};`}>
                <p class="topic-label text-white/70">Built as package example</p>
                <h2 class="mt-4 text-3xl font-semibold tracking-normal">{packageLabel}</h2>
                <p class="mt-4 text-lg font-black" style={`color: ${demo.secondary};`}>{demo.packagePrice}</p>
                <p class="mt-4 leading-7 text-white/70">{demo.bestFor}</p>
                <a href={packageRequestHref} class="mt-7 inline-flex items-center gap-2 rounded-full bg-white px-5 py-3 text-sm font-semibold text-ink transition hover:bg-[var(--demo-light)]">
                  {packageCtaLabel}
                  <MessageCircle class="h-4 w-4" aria-hidden="true" />
                </a>
              </div>
              <div class="demo-package-value__details rounded-lg border border-line bg-white p-7">
                <div class="grid gap-6 md:grid-cols-2">
                  <div>
                    <p class="topic-label topic-label--small" style={`color: ${demo.primary};`}>Included in this demo</p>
                    <ul class="demo-package-list mt-4">
                      {demo.includedScope.map((item) => (
                        <li><CircleCheck class="h-4 w-4" style={`color: ${demo.primary};`} aria-hidden="true" /> <span>{item}</span></li>
                      ))}
                    </ul>
                  </div>
                  <div>
                    <p class="topic-label topic-label--small" style={`color: ${demo.primary};`}>Value proof</p>
                    <ul class="demo-package-list mt-4">
                      {demo.valueProof.map((item) => (
                        <li><CircleCheck class="h-4 w-4" style={`color: ${demo.primary};`} aria-hidden="true" /> <span>{item}</span></li>
                      ))}
                    </ul>
                  </div>
                </div>
                <div class="demo-upgrade-path mt-6 rounded-lg p-5">
                  <p class="text-sm font-black uppercase tracking-normal" style={`color: ${demo.primary};`}>Upgrade path</p>
                  <p class="mt-2 leading-7 text-ink/70">{demo.upgradePath}</p>
                </div>
              </div>
            </div>
          </section>

          {demo.packageFit === "Custom Build" && (
            <section class="custom-flow-section px-5 py-16 sm:px-6 lg:px-8">
              <div class="mx-auto max-w-6xl">
                <div class="max-w-2xl">
                  <p class="topic-label" style={`color: ${demo.primary};`}>Custom flow planning</p>
                  <h2 class="mt-4 text-4xl font-semibold tracking-normal text-ink sm:text-5xl">Built around the steps customers need before they book or inquire.</h2>
                  <p class="mt-5 leading-8 text-ink/70">Custom Build examples show how the website can support a more specific journey than a standard page, from comparing packages to capturing the right lead details.</p>
                </div>
                <div class="custom-flow-grid mt-10">
                  {customFlowSteps.map((step, index) => (
                    <article class="custom-flow-card rounded-lg border border-line bg-white p-6">
                      <span class="custom-flow-card__index">0{index + 1}</span>
                      <h3 class="mt-5 text-xl font-semibold text-ink">{step.title}</h3>
                      <p class="mt-3 leading-7 text-ink/70">{step.detail}</p>
                    </article>
                  ))}
                </div>
                <div class="custom-build-preview mt-8">
                  <article class="custom-build-panel rounded-lg border border-line bg-white p-6">
                    <p class="topic-label topic-label--small" style={`color: ${demo.primary};`}>Package comparison</p>
                    <div class="mt-5 grid gap-3">
                      {customStudioPackages.map((item) => (
                        <div class="custom-package-row">
                          <div>
                            <h3 class="font-semibold text-ink">{item.name}</h3>
                            <p class="mt-1 text-sm leading-6 text-ink/62">{item.detail}</p>
                          </div>
                          <strong>{item.price}</strong>
                        </div>
                      ))}
                    </div>
                  </article>
                  <article class="custom-build-panel rounded-lg border border-line bg-white p-6">
                    <p class="topic-label topic-label--small" style={`color: ${demo.primary};`}>Lead capture preview</p>
                    <div class="custom-lead-preview mt-5">
                      {customLeadFields.map((field) => <span>{field}</span>)}
                    </div>
                  </article>
                  <article class="custom-build-panel custom-build-panel--dark rounded-lg p-6 text-white" style={`background: ${demo.dark};`}>
                    <p class="topic-label topic-label--small text-white/70">Integration planning</p>
                    <h3 class="mt-4 text-2xl font-semibold tracking-normal">Booking, CRM, and analytics notes before build.</h3>
                    <p class="mt-4 leading-7 text-white/70">Custom Build includes planning space for tools, follow-up workflows, tracking, and handoff decisions that a standard landing page does not need.</p>
                  </article>
                </div>
              </div>
            </section>
          )}

          <section id="offer" class="px-5 py-20 sm:px-6 lg:px-8" style={`background: ${demo.light};`}>
            <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.88fr_1.12fr] lg:items-start">
              <div>
                <p class="topic-label" style={`color: ${demo.primary};`}>Landing page structure</p>
                <h2 class="mt-4 text-4xl font-semibold tracking-normal text-ink sm:text-5xl">Designed around the first action customers should take.</h2>
                <p class="mt-5 leading-8 text-ink/70">This concept turns a local business into a focused online destination with a strong hero, practical sections, proof points, and a direct inquiry path.</p>
              </div>
              <div class="grid gap-4 sm:grid-cols-2">
                {demo.sections.map((section) => (
                  <article class="rounded-lg border border-line bg-white p-6 shadow-[0_10px_28px_rgba(17,24,39,0.06)]">
                    <CircleCheck class="h-6 w-6" style={`color: ${demo.primary};`} aria-hidden="true" />
                    <h3 class="mt-5 text-xl font-semibold text-ink">{section}</h3>
                    <p class="mt-3 leading-7 text-ink/70">A clear content block that helps visitors understand the offer and move toward a decision.</p>
                  </article>
                ))}
              </div>
            </div>
          </section>

          <section class="bg-white px-5 py-20 sm:px-6 lg:px-8">
            <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[1fr_0.78fr] lg:items-stretch">
              <div class="rounded-lg p-8 text-white" style={`background: ${demo.dark};`}>
                <p class="topic-label text-white/70">Featured offer</p>
                <h2 class="mt-4 text-4xl font-semibold tracking-normal sm:text-5xl">{demo.offer}</h2>
                <p class="mt-5 max-w-2xl leading-8 text-white/70">A landing page can place the best offer where customers see it immediately, then support it with menu, service, or package details below.</p>
              </div>
              <div class="rounded-lg border border-line bg-paper p-8">
                <MapPin class="h-7 w-7" style={`color: ${demo.primary};`} aria-hidden="true" />
                <h3 class="mt-5 text-2xl font-semibold text-ink">Local business ready</h3>
                <p class="mt-4 leading-8 text-ink/70">Built for mobile visitors who want location, hours, packages, and a fast way to contact or book.</p>
                <a href={packageRequestHref} class="mt-7 inline-flex items-center gap-2 rounded-full bg-ink px-5 py-3 text-sm font-semibold text-white transition hover:bg-moss">
                  {packageCtaLabel}
                  <MessageCircle class="h-4 w-4" aria-hidden="true" />
                </a>
              </div>
            </div>
          </section>
        </>
      </main>
    )}
  </body>
</html>